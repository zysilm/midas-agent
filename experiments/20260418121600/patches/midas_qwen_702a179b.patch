diff --git a/trace_detailed.py b/trace_detailed.py
new file mode 100644
index 000000000..fc3eb7c08
--- /dev/null
+++ b/trace_detailed.py
@@ -0,0 +1,40 @@
+import astropy.coordinates as coord
+import traceback
+
+
+# Let's monkey patch to see the exact flow
+original_getattr = coord.SkyCoord.__getattr__
+
+def debug_getattr(self, attr):
+    print(f"DEBUG: SkyCoord.__getattr__ called with attr='{attr}' (type: {type(attr)})")
+    import sys
+    # Print the current frame to see where this is called from
+    frame = sys._getframe(1)
+    print(f"DEBUG: Called from: {frame.f_code.co_filename}:{frame.f_lineno}")
+    try:
+        result = original_getattr(self, attr)
+        print(f"DEBUG: SkyCoord.__getattr__ returning: {result}")
+        return result
+    except Exception as e:
+        print(f"DEBUG: SkyCoord.__getattr__ raising: {e}")
+        print(f"DEBUG: Exception type: {type(e)}")
+        raise
+
+coord.SkyCoord.__getattr__ = debug_getattr
+
+
+class custom_coord(coord.SkyCoord):
+    @property
+    def prop(self):
+        print("Property getter called")
+        print("About to access random_attr")
+        return self.random_attr
+
+
+c = custom_coord('00h42m30s', '+41d12m00s', frame='icrs')
+print("About to access c.prop")
+try:
+    c.prop
+except Exception as e:
+    print(f"Final error: {e}")
+    traceback.print_exc()
