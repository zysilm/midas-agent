+#!/usr/bin/env python
+"""Comprehensive test for the is_fits fix"""
+
+from astropy.io.registry import identify_format
+from astropy.table import Table
+from astropy.io.fits import HDUList, TableHDU, BinTableHDU, GroupsHDU
+
+# Test 1: The original failing case
+print("Test 1: Original failing case")
+try:
+    result = identify_format("write", Table, "bububu.ecsv", None, [], {})
+    print(f"  Result: {result}")
+    print("  ✓ PASS")
+except Exception as e:
+    print(f"  ✗ FAIL: {type(e).__name__}: {e}")
+
+# Test 2: FITS file with extension
+print("\\nTest 2: FITS file with extension")
+try:
+    result = identify_format("write", Table, "test.fits", None, [], {})
+    print(f"  Result: {result}")
+    print("  ✓ PASS")
+except Exception as e:
+    print(f"  ✗ FAIL: {type(e).__name__}: {e}")
+
+# Test 3: Non-FITS file with extension
+print("\\nTest 3: Non-FITS file with extension")
+try:
+    result = identify_format("write", Table, "test.txt", None, [], {})
+    print(f"  Result: {result}")
+    print("  ✓ PASS")
+except Exception as e:
+    print(f"  ✗ FAIL: {type(e).__name__}: {e}")
+
+# Test 4: Test with actual FITS objects (should return True)
+print("\\nTest 4: Test with actual FITS objects")
+try:
+    # This should work for reading, not writing, but let's see what happens
+    result = identify_format("read", Table, None, None, [HDUList()], {})
+    print(f"  Result: {result}")
+    print("  ✓ PASS")
+except Exception as e:
+    print(f"  ✗ FAIL: {type(e).__name__}: {e}")
+
+# Test 5: Empty args with fileobj
+print("\\nTest 5: Empty args with fileobj")
+try:
+    result = identify_format("write", Table, None, "dummy", [], {})
+    print(f"  Result: {result}")
+    print("  ✓ PASS")
+except Exception as e:
+    print(f"  ✗ FAIL: {type(e).__name__}: {e}")
+
+print("\\nAll tests completed!")
