@@ -0,0 +1,42 @@
+import astropy.coordinates as coord
+
+
+class custom_coord(coord.SkyCoord):
+    @property
+    def prop(self):
+        return self.random_attr
+
+
+# Test the original issue
+print("Testing original issue...")
+try:
+    c = custom_coord('00h42m30s', '+41d12m00s', frame='icrs')
+    result = c.prop
+    print("ERROR: Should have raised AttributeError")
+except AttributeError as e:
+    print(f"AttributeError: {e}")
+    # Check if the error message is correct
+    error_msg = str(e)
+    if "random_attr" in error_msg:
+        print("SUCCESS: Error message correctly shows 'random_attr'")
+    elif "prop" in error_msg:
+        print("ISSUE: Error message incorrectly shows 'prop' instead of 'random_attr'")
+    else:
+        print("UNEXPECTED: Error message doesn't contain expected attribute names")
+
+# Test that normal SkyCoord behavior still works
+print("\\nTesting normal SkyCoord behavior...")
+try:
+    c2 = coord.SkyCoord('00h42m30s', '+41d12m00s', frame='icrs')
+    result = c2.ra
+    print("Normal attribute access works:", result)
+    
+    # Test non-existent attribute
+    try:
+        _ = c2.nonexistent
+        print("ERROR: Should have raised AttributeError")
+    except AttributeError as e:
+        print("Normal error message:", str(e))
+        
+except Exception as e:
+    print("Error in normal behavior:", e)
