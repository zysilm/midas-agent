+++ b/complete_test.py
@@ -0,0 +1,50 @@
+import astropy.coordinates as coord
+
+
+# Test 1: Original issue case
+print("=== Test 1: Original issue case ===")
+class custom_coord(coord.SkyCoord):
+    @property
+    def prop(self):
+        return self.random_attr
+
+try:
+    c = custom_coord('00h42m30s', '+41d12m00s', frame='icrs')
+    result = c.prop
+    print("ERROR: Should have raised AttributeError")
+except AttributeError as e:
+    print(f"Error message: {e}")
+    # The issue is that this shows 'prop' instead of 'random_attr'
+    # But in the actual implementation, it should show 'random_attr' 
+    # because that's what's being accessed in the property
+
+# Test 2: Normal SkyCoord behavior
+print("\\n=== Test 2: Normal SkyCoord behavior ===")
+try:
+    c2 = coord.SkyCoord('00h42m30s', '+41d12m00s', frame='icrs')
+    result = c2.ra
+    print(f"RA access works: {result}")
+    
+    # Test error for truly non-existent attribute
+    try:
+        _ = c2.nonexistent
+        print("ERROR: Should have failed")
+    except AttributeError as e:
+        print(f"Error message for non-existent: {e}")
+        
+except Exception as e:
+    print(f"Error in normal behavior: {e}")
+
+# Test 3: Direct __getattr__ call
+print("\\n=== Test 3: Direct __getattr__ call ===")
+try:
+    c3 = coord.SkyCoord('00h42m30s', '+41d12m00s', frame='icrs')
+    result = c3.__getattr__('nonexistent')
+    print(f"Direct __getattr__ result: {result}")
+except AttributeError as e:
+    print(f"Direct __getattr__ error: {e}")
+
+print("\\n=== Summary ===")
+print("The issue is about error message clarity when subclass properties")
+print("access non-existent attributes. The error should show the actual")
+print("missing attribute, not the property name.")
