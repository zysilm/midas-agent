--- /dev/null
+++ b/debug_issue.py
@@ -0,0 +1,25 @@
+import astropy.coordinates as coord
+
+
+class custom_coord(coord.SkyCoord):
+    @property
+    def prop(self):
+        print("Inside prop property")
+        return self.random_attr
+
+    def __getattr__(self, attr):
+        print(f"__getattr__ called with attr={attr}")
+        return super().__getattr__(attr)
+
+
+c = custom_coord('00h42m30s', '+41d12m00s', frame='icrs')
+print("About to access c.prop")
+print("Checking if prop is in class dict:")
+print("prop" in dir(custom_coord))
+print("Checking if prop is in class __dict__:")
+print("prop" in custom_coord.__dict__)
+try:
+    c.prop
+except Exception as e:
+    print(f"Exception type: {type(e)}")
+    print(f"Exception message: {e}")
