+#!/usr/bin/env python
+"""Simple debug to understand the exact issue."""
+
+import numpy as np
+from astropy.time import Time
+from astropy.timeseries import TimeSeries
+
+# Create the exact scenario from the issue
+time = Time(np.arange(100000, 100003), format='jd')
+ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+ts._required_columns = ["time", "flux"]
+
+print("Before removing flux:")
+print(f"  colnames: {ts.colnames}")
+print(f"  _required_columns: {ts._required_columns}")
+
+# Let's manually call the check to see what happens
+try:
+    ts._check_required_columns()
+    print("Check passed")
+except ValueError as e:
+    print(f"Check failed with: {e}")
+
+# Now let's see what happens if we remove the column and then check
+print("\\nRemoving flux column...")
+# We'll simulate what happens by directly manipulating the state
+ts_copy = ts.copy()
+ts_copy._required_columns = ["time", "flux"]
+# Remove the column manually (but we'll do it in a way that doesn't trigger the check)
+del ts_copy['flux']
+
+print("After removing flux:")
+print(f"  colnames: {ts_copy.colnames}")
+print(f"  _required_columns: {ts_copy._required_columns}")
+
+# Now check what the comparison would be
+required_columns = ts_copy._required_columns
+colnames_subset = ts_copy.colnames[:len(required_columns)]
+
+print(f"required_columns: {required_columns}")
+print(f"colnames_subset: {colnames_subset}")
+print(f"Are they equal? {colnames_subset != required_columns}")
+
+# What we should show in the error message
+missing_cols = [col for col in required_columns if col not in ts_copy.colnames]
+print(f"Missing columns: {missing_cols}")
