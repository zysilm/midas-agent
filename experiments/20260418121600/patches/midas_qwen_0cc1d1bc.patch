+#!/usr/bin/env python
+"""Final verification that the fix works correctly."""
+
+import numpy as np
+from astropy.time import Time
+from astropy.timeseries import TimeSeries
+
+def test_original_issue():
+    """Test the exact scenario from the issue."""
+    print("=== Testing Original Issue ===")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["time", "flux"]                                   
+    
+    try:
+        ts.remove_column("flux")
+        print("ERROR: Should have raised ValueError")
+        return False
+    except ValueError as e:
+        error_msg = str(e)
+        print(f"Error message: {error_msg}")
+        
+        # Check that the error message is now clear
+        if "missing required columns" in error_msg and "flux" in error_msg:
+            print("✓ Error message is now clear and informative")
+            return True
+        else:
+            print("✗ Error message is still unclear")
+            return False
+
+def test_multiple_missing():
+    """Test with multiple missing columns."""
+    print("\\n=== Testing Multiple Missing Columns ===")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7], "magnitude": [1.0, 1.1, 1.2]})
+    ts._required_columns = ["time", "flux", "magnitude"]
+    
+    try:
+        ts.remove_column("flux")  # This should fail
+        print("ERROR: Should have raised ValueError")
+        return False
+    except ValueError as e:
+        error_msg = str(e)
+        print(f"Error message: {error_msg}")
+        
+        # Should mention the missing column
+        if "missing required columns" in error_msg and "flux" in error_msg:
+            print("✓ Error message correctly identifies missing column")
+            return True
+        else:
+            print("✗ Error message doesn't identify missing column properly")
+            return False
+
+def test_normal_operation():
+    """Test that normal operations still work."""
+    print("\\n=== Testing Normal Operations ===")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["time", "flux"]
+    
+    # This should work fine
+    try:
+        ts._check_required_columns()
+        print("✓ Required columns check passes when all columns present")
+    except Exception as e:
+        print(f"✗ Unexpected error: {e}")
+        return False
+    
+    # Adding a column should work
+    try:
+        ts.add_column([1.0, 1.1, 1.2], name="magnitude")
+        ts._check_required_columns()
+        print("✓ Adding column works correctly")
+    except Exception as e:
+        print(f"✗ Error adding column: {e}")
+        return False
+        
+    return True
+
+if __name__ == "__main__":
+    success1 = test_original_issue()
+    success2 = test_multiple_missing()
+    success3 = test_normal_operation()
+    
+    if success1 and success2 and success3:
+        print("\\n🎉 All tests passed! The fix is working correctly.")
+    else:
+        print("\\n❌ Some tests failed.")
+        exit(1)
