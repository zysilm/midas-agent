+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7], "magnitude": [1.0, 1.1, 1.2]})
+    ts._required_columns = ["time", "flux", "magnitude"]
+    
+    print(f"Initial columns: {ts.colnames}")
+    print(f"Required columns: {ts._required_columns}")
+    
+    # Try to remove flux first
+    try:
+        ts.remove_column("flux")
+        print("ERROR: Should have failed")
+    except ValueError as e:
+        print(f"After removing flux: {ts.colnames}")
+        print(f"Got: {e}")
+        
+    # Let's try a different approach - create a new ts and remove one by one
+    print("\\n--- Creating fresh TS ---")
+    ts2 = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7], "magnitude": [1.0, 1.1, 1.2]})
