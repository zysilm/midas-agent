+#!/usr/bin/env python
+"""Test script to verify RST header_rows functionality."""
+
+import io
+from astropy.table import QTable
+import astropy.units as u
+
+
+def test_rst_header_rows():
+    """Test that RST format supports header_rows parameter."""
+    # Create test table
+    tbl = QTable({'wave': [350, 950]*u.nm, 'response': [0.7, 1.2]*u.count})
+    
+    # Test 1: Default behavior (should work as before)
+    output = io.StringIO()
+    tbl.write(output, format="ascii.rst")
+    result = output.getvalue()
+    assert "wave" in result
+    assert "response" in result
+    assert "350.0" in result
+    assert "950.0" in result
+    
+    # Test 2: With header_rows parameter
+    output = io.StringIO()
+    tbl.write(output, format="ascii.rst", header_rows=["name", "unit"])
+    result = output.getvalue()
+    assert "wave" in result
+    assert "response" in result
+    assert "nm" in result  # unit should appear
+    assert "ct" in result  # unit should appear
+    assert "350.0" in result
+    assert "950.0" in result
+    
+    # Test 3: With just name header row
+    output = io.StringIO()
+    tbl.write(output, format="ascii.rst", header_rows=["name"])
+    result = output.getvalue()
+    assert "wave" in result
+    assert "response" in result
+    assert "350.0" in result
+    assert "950.0" in result
+    
+    print("All RST header_rows tests passed!")
+
+
+if __name__ == "__main__":
+    test_rst_header_rows()
