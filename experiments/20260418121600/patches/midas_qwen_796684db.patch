+#!/usr/bin/env python3
+
+import dataclasses
+import numpy as np
+import astropy.units as u
+
+
+@dataclasses.dataclass
+class DuckArray(np.lib.mixins.NDArrayOperatorsMixin):
+    ndarray: u.Quantity
+
+    @property
+    def unit(self) -> u.UnitBase:
+        return self.ndarray.unit
+
+    def __array_ufunc__(self, function, method, *inputs, **kwargs):
+        inputs = [inp.ndarray if isinstance(inp, DuckArray) else inp for inp in inputs]
+        for inp in inputs:
+            if isinstance(inp, np.ndarray):
+                result = inp.__array_ufunc__(function, method, *inputs, **kwargs)
+                if result is not NotImplemented:
+                    return DuckArray(result)
+        return NotImplemented
+
+
+def test_edge_cases():
+    print("Testing edge cases for the fix...")
+    
+    # Test 1: Make sure normal operations still work
+    print("Test 1: Normal Quantity operations")
+    q1 = 5 * u.m
+    q2 = 3 * u.m
+    result = q1 + q2
+    print(f"  5m + 3m = {result}")
+    
+    # Test 2: DuckArray with compatible units (should work)
+    print("Test 2: DuckArray with compatible units")
+    result = DuckArray(1 * u.mm) + (1 * u.m)
+    print(f"  DuckArray(1mm) + 1m = {result}")
+    
+    # Test 3: DuckArray with same units (should work)
+    print("Test 3: DuckArray with same units")
+    result = (1 * u.mm) + DuckArray(1 * u.mm)
+    print(f"  1mm + DuckArray(1mm) = {result}")
+    
+    # Test 4: The main issue - different units (should now work)
+    print("Test 4: Different units (main issue)")
+    result = (1 * u.m) + DuckArray(1 * u.mm)
+    print(f"  1m + DuckArray(1mm) = {result}")
+    
+    # Test 5: Test with other ufuncs that might fail
+    print("Test 5: Other ufuncs")
+    result = np.add((1 * u.m), DuckArray(1 * u.mm))
+    print(f"  np.add(1m, DuckArray(1mm)) = {result}")
+    
+    # Test 6: Test with compatible operations
+    print("Test 6: Compatible operations")
+    result = (1 * u.m) + DuckArray(2 * u.mm)  # 1m + 2mm = 1.002m
+    print(f"  1m + DuckArray(2mm) = {result}")
+    
+    # Test 7: Test that we still raise errors for truly incompatible cases
+    print("Test 7: Testing that errors are still raised appropriately")
+    try:
+        # This should still raise an error for incompatible operations
+        result = np.sin(DuckArray(1 * u.mm))  # sin on non-dimensionless
+        print(f"  sin(DuckArray(1mm)) = {result}")
+    except Exception as e:
+        print(f"  sin(DuckArray(1mm)) correctly raised: {type(e).__name__}")
+    
+    print("All edge case tests completed!")
+
+
+if __name__ == "__main__":
+    test_edge_cases()
