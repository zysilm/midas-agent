+#!/usr/bin/env python3
+
+import dataclasses
+import numpy as np
+import astropy.units as u
+
+
+@dataclasses.dataclass
+class DuckArray(np.lib.mixins.NDArrayOperatorsMixin):
+    ndarray: u.Quantity
+
+    @property
+    def unit(self) -> u.UnitBase:
+        return self.ndarray.unit
+
+    def __array_ufunc__(self, function, method, *inputs, **kwargs):
+
+        inputs = [inp.ndarray if isinstance(inp, DuckArray) else inp for inp in inputs]
+
+        for inp in inputs:
+            if isinstance(inp, np.ndarray):
+                result = inp.__array_ufunc__(function, method, *inputs, **kwargs)
+                if result is not NotImplemented:
+                    return DuckArray(result)
+
+        return NotImplemented
+
+
+def test_comprehensive():
+    print("Comprehensive testing of the fix...")
+    
+    # Test 1: Basic operations that should work
+    print("Test 1: Basic Quantity operations")
+    q1 = 5 * u.m
+    q2 = 3 * u.m
+    result = q1 + q2
+    print(f"  5m + 3m = {result}")
+    
+    # Test 2: DuckArray with compatible units
+    print("Test 2: DuckArray with compatible units")
+    result = DuckArray(1 * u.mm) + (1 * u.m)
+    print(f"  DuckArray(1mm) + 1m = {result}")
+    
+    # Test 3: DuckArray with same units
+    print("Test 3: DuckArray with same units")
+    result = (1 * u.mm) + DuckArray(1 * u.mm)
+    print(f"  1mm + DuckArray(1mm) = {result}")
+    
+    # Test 4: The main issue - different units (this was failing before)
+    print("Test 4: Different units (main issue)")
+    result = (1 * u.m) + DuckArray(1 * u.mm)
+    print(f"  1m + DuckArray(1mm) = {result}")
+    
+    # Test 5: Other operations
+    print("Test 5: Other operations")
+    result = (1 * u.m) * DuckArray(2 * u.mm)
+    print(f"  1m * DuckArray(2mm) = {result}")
+    
+    # Test 6: Division
+    print("Test 6: Division")
+    result = (10 * u.m) / DuckArray(2 * u.mm)
+    print(f"  10m / DuckArray(2mm) = {result}")
+    
+    # Test 7: Comparison operations
+    print("Test 7: Comparison operations")
+    result = (1 * u.m) > DuckArray(500 * u.mm)
+    print(f"  1m > DuckArray(500mm) = {result}")
+    
+    # Test 8: Make sure regular numpy arrays still work
+    print("Test 8: Regular numpy arrays")
+    result = (1 * u.m) + np.array([1, 2, 3]) * u.mm
+    print(f"  1m + [1,2,3]mm = {result}")
+    
+    print("All tests completed successfully!")
+
+
+if __name__ == "__main__":
+    test_comprehensive()
