+#!/usr/bin/env python
+"""
+Debug script to check if the FutureWarning is properly raised.
+"""
+import warnings
+import numpy as np
+from astropy.table import Table
+
+# Enable all warnings
+warnings.simplefilter('always')
+
+print("Testing FutureWarning for structured array conversion...")
+
+# Test if warnings module works
+print("Testing basic warning:")
+warnings.warn("Test warning", FutureWarning)
+
+# Create a structured array
+dtype = [('a', 'i4'), ('b', 'f4')]
+structured_data = np.array([(1, 2.0), (3, 4.0), (5, 6.0)], dtype=dtype)
+print(f"Original structured array: {structured_data}")
+
+# Add to Table - this should trigger the warning
+print("Creating table and adding structured array...")
+try:
+    t = Table()
+    t['col1'] = structured_data
+    print(f"Table column type: {type(t['col1'])}")
+    print("SUCCESS: Structured array was added to table")
+except Exception as e:
+    print(f"ERROR: {e}")
