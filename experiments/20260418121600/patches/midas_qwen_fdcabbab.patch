+#!/usr/bin/env python
+"""
+Script to reproduce the structured array auto-transform issue.
+"""
+import numpy as np
+from astropy.table import Table, Column, NdarrayMixin
+import warnings
+
+# Capture warnings
+warnings.simplefilter('always', FutureWarning)
+
+print("Testing structured array handling in Table...")
+
+# Create a structured array
+dtype = [('a', 'i4'), ('b', 'f4')]
+structured_data = np.array([(1, 2.0), (3, 4.0), (5, 6.0)], dtype=dtype)
+print(f"Original structured array: {structured_data}")
+print(f"Type: {type(structured_data)}")
+
+# Add to Table - this should trigger the auto-transform
+try:
+    t = Table()
+    t['col1'] = structured_data
+    print(f"Table column type: {type(t['col1'])}")
+    print(f"Table column data: {t['col1']}")
+    print("SUCCESS: Structured array was added to table")
+except Exception as e:
+    print(f"ERROR: {e}")
+
+# Also test with Column wrapping
+print("\\nTesting with explicit Column wrapping:")
+try:
+    t2 = Table()
+    t2['col2'] = Column(structured_data)
+    print(f"Table column type: {type(t2['col2'])}")
+    print(f"Table column data: {t2['col2']}")
+    print("SUCCESS: Column-wrapped structured array worked")
+except Exception as e:
+    print(f"ERROR: {e}")
+
+# Test with different structured array
+print("\\nTesting with different structured array:")
+dtype2 = [('x', 'f8'), ('y', 'i4'), ('z', 'u2')]
+structured_data2 = np.array([(1.1, 2, 3), (4.4, 5, 6)], dtype=dtype2)
+print(f"Original structured array: {structured_data2}")
+print(f"Type: {type(structured_data2)}")
+
+try:
+    t3 = Table()
+    t3['col3'] = structured_data2
+    print(f"Table column type: {type(t3['col3'])}")
+    print(f"Table column data: {t3['col3']}")
+    print("SUCCESS: Second structured array was added to table")
+except Exception as e:
+    print(f"ERROR: {e}")
