+#!/usr/bin/env python
+
+import numpy as np
+from astropy.time import Time
+from astropy.timeseries import TimeSeries
+
+# Debug the exact scenario
+time = Time(np.arange(100000, 100003), format='jd')
+ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+ts._required_columns = ["time", "flux"]                                   
+
+print("=== DEBUG INFO ===")
+print("Required columns:", ts._required_columns)
+print("Actual columns:", ts.colnames)
+print("Length of required columns:", len(ts._required_columns))
+print("Length of actual columns:", len(ts.colnames))
+print("First len(required_columns) actual columns:", ts.colnames[:len(ts._required_columns)])
+
+# Simulate the check that's failing
+required_columns = ts._required_columns
+actual_columns = ts.colnames
+print("\\n=== CHECK LOGIC ===")
+print("required_columns:", required_columns)
+print("actual_columns[:len(required_columns)]:", actual_columns[:len(required_columns)])
+print("Are they equal?", actual_columns[:len(required_columns)] == required_columns)
+
+# What should be the correct error message?
+print("\\n=== ANALYSIS ===")
+print("We have", len(required_columns), "required columns:", required_columns)
+print("We have", len(actual_columns), "actual columns:", actual_columns)
+print("The issue is that we're missing required columns, not that the first column is wrong")
