+#!/usr/bin/env python
+
+import numpy as np
+from astropy.time import Time
+from astropy.timeseries import TimeSeries
+
+print("=== Test 1: Original issue - removing one required column ===")
+try:
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["time", "flux"]                                   
+    ts.remove_column("flux")
+    print("ERROR: Should have failed!")
+except ValueError as e:
+    print("Got expected error:", str(e))
+
+print("\\n=== Test 2: Removing multiple required columns ===")
+try:
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7], "magnitude": [10.5, 10.6, 10.7]})
+    ts._required_columns = ["time", "flux", "magnitude"]                                   
+    ts.remove_column("flux")
+    ts.remove_column("magnitude")
+    print("ERROR: Should have failed!")
+except ValueError as e:
+    print("Got expected error:", str(e))
+
+print("\\n=== Test 3: Removing non-required column (should work) ===")
+try:
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7], "extra": [1, 2, 3]})
+    ts._required_columns = ["time", "flux"]                                   
+    ts.remove_column("extra")
+    print("Successfully removed extra column")
+    print("Columns now:", ts.colnames)
+except Exception as e:
+    print("Unexpected error:", type(e).__name__, "-", str(e))
+
+print("\\n=== Test 4: Removing first required column (should fail with different message) ===")
+try:
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["time", "flux"]                                   
+    ts.remove_column("time")
+    print("ERROR: Should have failed!")
+except ValueError as e:
+    print("Got expected error:", str(e))
