+print(f"  Left: {type(cm_working.left)} - n_inputs: {cm_working.left.n_inputs}, n_outputs: {cm_working.left.n_outputs}")
+print(f"  Right: {type(cm_working.right)} - n_inputs: {cm_working.right.n_inputs}, n_outputs: {cm_working.right.n_outputs}")
+
+print("2a. Calling _separable on left (Pix2Sky_TAN() & Linear1D(10)):")
+left_working = _separable(cm_working.left)
+print(f"   Result shape: {left_working.shape}")
+print(f"   Result:\\n{left_working}")
+
+print("2b. Calling _separable on right (Linear1D(5)):")
+right_working = _separable(cm_working.right)
+print(f"   Result shape: {right_working.shape}")
+print(f"   Result:\\n{right_working}")
+
+print("2c. Calling _cstack with these results:")
+cstack_working = _cstack(left_working, right_working)
+print(f"   Final _cstack result:\\n{cstack_working}")
+
+print("\\n=== Step 3: Direct separability_matrix calls ===")
+print("Nested case result:")
+nested_result = separability_matrix(cm_nested)
+print(nested_result)
+
+print("Working case result:")
