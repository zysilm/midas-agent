+print(f"  Type: {type(cm_nested)}")
+print(f"  Op: {cm_nested.op}")
+print(f"  Left: {type(cm_nested.left)} - n_inputs: {cm_nested.left.n_inputs}, n_outputs: {cm_nested.left.n_outputs}")
+print(f"  Right: {type(cm_nested.right)} - n_inputs: {cm_nested.right.n_inputs}, n_outputs: {cm_nested.right.n_outputs}")
+
+# Step 1: Call _separable on the nested model
+print("\\n=== Step 1: _separable(cm_nested) ===")
+print("This should call _separable on left and right recursively")
+
+print("1a. Calling _separable on left (Pix2Sky_TAN):")
+left_result = _separable(cm_nested.left)
+print(f"   Result shape: {left_result.shape}")
+print(f"   Result:\\n{left_result}")
+
+print("1b. Calling _separable on right (Linear1D(10) & Linear1D(5)):")
+right_result = _separable(cm_nested.right)
+print(f"   Result shape: {right_result.shape}")
+print(f"   Result:\\n{right_result}")
+
+print("1c. Calling _cstack with these results:")
+print(f"   left shape: {left_result.shape}")
+print(f"   right shape: {right_result.shape}")
+print(f"   noutp (computed): {_compute_n_outputs(left_result, right_result)}")
+cstack_result = _cstack(left_result, right_result)
+print(f"   Final _cstack result:\\n{cstack_result}")
