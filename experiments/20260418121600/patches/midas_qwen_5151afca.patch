+print("cm_explicit.left.n_outputs:", cm_explicit.left.n_outputs)
+print("cm_explicit.right.n_inputs:", cm_explicit.right.n_inputs)
+print("cm_explicit.right.n_outputs:", cm_explicit.right.n_outputs)
