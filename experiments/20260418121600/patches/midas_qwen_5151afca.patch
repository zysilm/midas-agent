+#!/usr/bin/env python
+
+from astropy.modeling import models as m
+from astropy.modeling.separable import separability_matrix, _separable, _coord_matrix, _cstack, _compute_n_outputs
+import numpy as np
+
+print("Deep debugging...")
+
+# Test the exact problematic case
+cm_nested = m.Pix2Sky_TAN() & (m.Linear1D(10) & m.Linear1D(5))
+print("Nested model structure:")
+print(f"  Type: {type(cm_nested)}")
+print(f"  Op: {cm_nested.op}")
+print(f"  Left: {type(cm_nested.left)} - n_inputs: {cm_nested.left.n_inputs}, n_outputs: {cm_nested.left.n_outputs}")
+print(f"  Right: {type(cm_nested.right)} - n_inputs: {cm_nested.right.n_inputs}, n_outputs: {cm_nested.right.n_outputs}")
+
+# Let's manually trace the _separable call for the nested case
+print("\\nTracing _separable for nested model:")
+print("1. Calling _separable on left model (Pix2Sky_TAN):")
+left_separable = _separable(cm_nested.left)
+print(f"   Result shape: {left_separable.shape}")
+print(f"   Result:\\n{left_separable}")
+
+print("2. Calling _separable on right model (Linear1D(10) & Linear1D(5)):")
+right_separable = _separable(cm_nested.right)
+print(f"   Result shape: {right_separable.shape}")
+print(f"   Result:\\n{right_separable}")
+
+print("3. Calling _cstack with these results:")
+noutp = _compute_n_outputs(left_separable, right_separable)
+print(f"   noutp: {noutp}")
+result = _cstack(left_separable, right_separable)
+print(f"   Final result:\\n{result}")
+
+print("\\n4. What should happen for the right model:")
+print("   Right model is Linear1D(10) & Linear1D(5)")
+print("   This should be handled by _separable recursively")
+print("   Let's trace that:")
+print("   - Linear1D(10) has n_inputs=1, n_outputs=1")
+print("   - Linear1D(5) has n_inputs=1, n_outputs=1")
+print("   - Combined should have n_inputs=2, n_outputs=2")
+print("   - Expected separability matrix should be [[True, False], [False, True]]")
+
+# Let's also test the working case for comparison
+print("\\n5. Working case comparison:")
+cm_working = m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)
+print(f"Working model right side type: {type(cm_working.right)}")
+print(f"Working model right side n_inputs: {cm_working.right.n_inputs}")
+print(f"Working model right side n_outputs: {cm_working.right.n_outputs}")
+
+# Let's see what _coord_matrix does for a simple Linear1D
+print("\\n6. Testing _coord_matrix on simple Linear1D:")
+simple_linear = m.Linear1D(10)
+print(f"Simple Linear1D n_inputs: {simple_linear.n_inputs}")
+print(f"Simple Linear1D n_outputs: {simple_linear.n_outputs}")
+coord_simple = _coord_matrix(simple_linear, 'left', 2)  # 2 outputs total
+print(f"Coord matrix for simple Linear1D:\\n{coord_simple}")
+
+# Let's also test what happens when we call _separable on a simple Linear1D
+print("\\n7. Testing _separable on simple Linear1D:")
+sep_simple = _separable(simple_linear)
+print(f"Separability result for simple Linear1D:\\n{sep_simple}")
+print(f"Shape: {sep_simple.shape}")
