+#!/usr/bin/env python
+
+from astropy.modeling import models as m
+from astropy.modeling.separable import separability_matrix
+
+print("Testing separability matrix issue...")
+
+# Test case 1: Simple compound model
+print("\\n1. Simple compound model (Linear1D & Linear1D):")
+cm = m.Linear1D(10) & m.Linear1D(5)
+result1 = separability_matrix(cm)
+print("Result:")
+print(result1)
+print("Expected: diagonal matrix")
+
+# Test case 2: More complex compound model
+print("\\n2. Complex compound model (Pix2Sky_TAN() & Linear1D & Linear1D):")
+result2 = separability_matrix(m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5))
+print("Result:")
+print(result2)
+print("Expected: separable structure")
+
+# Test case 3: Nested compound model (the problematic case)
+print("\\n3. Nested compound model (Pix2Sky_TAN() & (Linear1D & Linear1D)):")
+cm_nested = m.Pix2Sky_TAN() & (m.Linear1D(10) & m.Linear1D(5))
+result3 = separability_matrix(cm_nested)
+print("Result:")
+print(result3)
+print("This should be the same as case 2 but it's not!")
+
+# Test case 4: Let's also test the individual components
+print("\\n4. Individual components:")
+print("Pix2Sky_TAN n_inputs:", m.Pix2Sky_TAN().n_inputs)
+print("Pix2Sky_TAN n_outputs:", m.Pix2Sky_TAN().n_outputs)
+print("Linear1D(10) n_inputs:", m.Linear1D(10).n_inputs)
+print("Linear1D(10) n_outputs:", m.Linear1D(10).n_outputs)
+print("Linear1D(5) n_inputs:", m.Linear1D(5).n_inputs)
+print("Linear1D(5) n_outputs:", m.Linear1D(5).n_outputs)
+
+print("\\n5. Testing with explicit parentheses:")
+cm_explicit = m.Pix2Sky_TAN() & (m.Linear1D(10) & m.Linear1D(5))
+print("cm_explicit type:", type(cm_explicit))
+print("cm_explicit.op:", cm_explicit.op)
