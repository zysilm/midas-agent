         Overrides getattr to return coordinates that this can be transformed
         to, based on the alias attr in the primary transform graph.
         """
+        # First check if attr is a property or other descriptor on the class.
+        # This is needed to allow subclass properties to raise their own
+        # AttributeError with a meaningful message rather than having
+        # __getattr__ claim the property doesn't exist.
+        for attr_class in type(self).__mro__:
+            if attr in attr_class.__dict__:
+                attr_val = attr_class.__dict__[attr]
+                if hasattr(attr_val, '__get__'):
+                    return attr_val.__get__(self, type(self))
+                break
