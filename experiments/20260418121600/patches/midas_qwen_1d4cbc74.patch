+#!/usr/bin/env python
+"""
+Detailed trace of the separability computation
+"""
+from astropy.modeling import models as m
+from astropy.modeling.separable import _separable, _cstack, _coord_matrix
+
+print("Detailed trace of separability computation")
+print("=" * 50)
+
+# Create the models
+cm = m.Linear1D(10) & m.Linear1D(5)
+complex_model = m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)
+nested_model = m.Pix2Sky_TAN() & cm
+
+print("1. Working case: complex_model = Pix2Sky_TAN() & Linear1D(10) & Linear1D(5)")
+print(f"   complex_model.left = {complex_model.left}")
+print(f"   complex_model.right = {complex_model.right}")
+print(f"   complex_model.op = {complex_model.op}")
+print()
+
+print("2. Broken case: nested_model = Pix2Sky_TAN() & (Linear1D(10) & Linear1D(5))")
+print(f"   nested_model.left = {nested_model.left}")
+print(f"   nested_model.right = {nested_model.right}")
+print(f"   nested_model.op = {nested_model.op}")
+print()
+
+print("3. Let's manually compute what should happen in _separable for nested_model:")
+print("   _separable(nested_model) -> _operators['&'](_separable(nested_model.left), _separable(nested_model.right))")
+print("   _separable(nested_model.left) = _separable(Pix2Sky_TAN()) = [[1. 1.], [1. 1.]]")
+print("   _separable(nested_model.right) = _separable(cm) = [[1. 0.], [0. 1.]]")
+print("   Then _cstack([[1. 1.], [1. 1.]], [[1. 0.], [0. 1.]]) should give:")
+print("   [[1. 1. 1. 0.], [1. 1. 0. 1.]]")
+print()
+
+print("4. But what we actually get from the broken case:")
+print("   Let's trace through _cstack manually:")
+print("   noutp = _compute_n_outputs(left, right) = _compute_n_outputs(Pix2Sky_TAN(), cm)")
+print("   cm has n_outputs=2, n_inputs=2")
+print("   Pix2Sky_TAN() has n_outputs=2, n_inputs=2")
+print("   So noutp = 2 + 2 = 4")
+print()
+
+# Let's compute what _cstack should do
+print("5. Manual _cstack computation:")
+print("   cleft = _coord_matrix(Pix2Sky_TAN(), 'left', 4)")
+cleft = _coord_matrix(m.Pix2Sky_TAN(), 'left', 4)
+print(cleft)
+print()
+
+print("   cright = _coord_matrix(cm, 'right', 4)")
+try:
+    cright = _coord_matrix(cm, 'right', 4)
+    print(cright)
+except Exception as e:
+    print(f"Error in _coord_matrix(cm, 'right', 4): {e}")
+    # Let's see what happens if we use the recursive approach
+    print("   Let's see what _separable(cm) gives us:")
+    separable_cm = _separable(cm)
+    print(f"   _separable(cm) = {separable_cm}")
+    print("   This should be used instead of _coord_matrix(cm, 'right', 4)")
+print()
+
+print("6. The real issue:")
+print("   In _cstack, when right is a Model (including CompoundModel),")
+print("   it calls _coord_matrix(right, 'right', noutp)")
+print("   But for CompoundModel, this should not be done directly.")
+print("   Instead, we should use the recursive approach that _separable already does.")
+print("   The problem is that _cstack is being called with the result of _separable,")
+print("   not with the original models.")
