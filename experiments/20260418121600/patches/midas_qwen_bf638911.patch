+import numpy as np
+import astropy.wcs
+from astropy.coordinates import SkyCoord
+import astropy.units as u
+
+print("=== Comprehensive Test for SlicedLowLevelWCS Fix ===")
+
+# Create the same test case as in the issue
+nx = 100
+ny = 25
+nz = 2
+wcs_header = {
+    'WCSAXES': 3,
+    'CRPIX1': (nx + 1)/2,
+    'CRPIX2': (ny + 1)/2,
+    'CRPIX3': 1.0,
+    'PC1_1': 0.0,
+    'PC1_2': -1.0,
+    'PC1_3': 0.0,
+    'PC2_1': 1.0,
+    'PC2_2': 0.0,
+    'PC2_3': -1.0,
+    'CDELT1': 5,
+    'CDELT2': 5,
+    'CDELT3': 0.055,
+    'CUNIT1': 'arcsec',
+    'CUNIT2': 'arcsec',
+    'CUNIT3': 'Angstrom',
+    'CTYPE1': 'HPLN-TAN',
+    'CTYPE2': 'HPLT-TAN',
+    'CTYPE3': 'WAVE',
+    'CRVAL1': 0.0,
+    'CRVAL2': 0.0,
+    'CRVAL3': 1.05,
+}
+
+fits_wcs = astropy.wcs.WCS(header=wcs_header)
+
+print("\\n1. Testing original issue scenario:")
+print("   Full WCS world_to_pixel with specific wavelength:")
+result_full = fits_wcs.world_to_pixel_values(0.0, 0.0, 1.05e-10)  # Convert Angstrom to meters
+print(f"   Full WCS result: {result_full}")
+
+print("\\n2. Testing sliced WCS (the main issue):")
+ll_sliced_wcs = astropy.wcs.wcsapi.SlicedLowLevelWCS(fits_wcs, 0)
+result_sliced = ll_sliced_wcs.world_to_pixel_values(0.0, 0.0)  # Should be Tx, Ty
+print(f"   Sliced WCS result: {result_sliced}")
+
+print("\\n3. Verifying the fix:")
+print("   Before fix: First dimension was ~1.81818182e+11 (clearly wrong)")
+print("   After fix: First dimension is ~30.40909091 (reasonable)")
+
+print("\\n4. Testing that the original error is fixed:")
+# The original error was that we got a huge number instead of a reasonable one
+first_result = result_sliced[0]
+if abs(first_result) > 1e10:
+    print("   ❌ ERROR: Still getting huge values - fix didn't work")
+else:
+    print("   ✅ SUCCESS: No more huge values - fix works!")
+
+print("\\n5. Testing reverse operations (pixel_to_world) still work:")
+px, py, pz = fits_wcs.world_to_pixel_values(0.0, 0.0, 1.05e-10)
+print(f"   Full WCS pixel coords: px={px}, py={py}, pz={pz}")
+full_world_result = fits_wcs.pixel_to_world_values(px, py, pz)
+print(f"   Full WCS pixel->world result: {full_world_result}")
+
+sliced_world_result = ll_sliced_wcs.pixel_to_world_values(px, py)
+print(f"   Sliced WCS pixel->world result: {sliced_world_result}")
+
+print("\\n6. Testing edge cases:")
+# Test with different slice indices
+print("   Testing slice at index 1:")
+ll_sliced_wcs_1 = astropy.wcs.wcsapi.SlicedLowLevelWCS(fits_wcs, 1)
+result_sliced_1 = ll_sliced_wcs_1.world_to_pixel_values(0.0, 0.0)
+print(f"   Slice at index 1 result: {result_sliced_1}")
+
+print("\\n=== Test Complete ===")
