+import numpy as np
+import astropy.wcs
+from astropy.coordinates import SkyCoord
+import astropy.units as u
+
+print("Creating test WCS...")
+nx = 100
+ny = 25
+nz = 2
+wcs_header = {
+    'WCSAXES': 3,
+    'CRPIX1': (nx + 1)/2,
+    'CRPIX2': (ny + 1)/2,
+    'CRPIX3': 1.0,
+    'PC1_1': 0.0,
+    'PC1_2': -1.0,
+    'PC1_3': 0.0,
+    'PC2_1': 1.0,
+    'PC2_2': 0.0,
+    'PC2_3': -1.0,
+    'CDELT1': 5,
+    'CDELT2': 5,
+    'CDELT3': 0.055,
+    'CUNIT1': 'arcsec',
+    'CUNIT2': 'arcsec',
+    'CUNIT3': 'Angstrom',
+    'CTYPE1': 'HPLN-TAN',
+    'CTYPE2': 'HPLT-TAN',
+    'CTYPE3': 'WAVE',
+    'CRVAL1': 0.0,
+    'CRVAL2': 0.0,
+    'CRVAL3': 1.05,
+}
+
+fits_wcs = astropy.wcs.WCS(header=wcs_header)
+
+print("Testing full WCS...")
+# Test the full WCS
+pt = SkyCoord(Tx=0*u.arcsec, Ty=0*u.arcsec, frame=astropy.wcs.utils.wcs_to_celestial_frame(fits_wcs))
+result_full = fits_wcs.world_to_pixel(pt, 1.05*u.angstrom)
+print(f"Full WCS result: {result_full}")
+
+print("\\nTesting sliced WCS...")
+# Test the sliced WCS
+ll_sliced_wcs = astropy.wcs.wcsapi.SlicedLowLevelWCS(fits_wcs, 0)
+hl_sliced_wcs = astropy.wcs.wcsapi.HighLevelWCSWrapper(ll_sliced_wcs)
+result_sliced = hl_sliced_wcs.world_to_pixel(pt)
+print(f"Sliced WCS result: {result_sliced}")
+
+print("\\nTesting reverse operations...")
+# Test reverse operations to confirm they work
+px, py, pz = fits_wcs.world_to_pixel(pt, 1.05*u.Angstrom)
+print(f"Full WCS pixel coords: px={px}, py={py}, pz={pz}")
+full_world_result = fits_wcs.pixel_to_world(px, py, pz)
+print(f"Full WCS pixel->world result: {full_world_result}")
+
+sliced_world_result = hl_sliced_wcs.pixel_to_world(px, py)
+print(f"Sliced WCS pixel->world result: {sliced_world_result}")
+
+print("\\nExpected behavior:")
+print("Both world_to_pixel operations should return similar results for the first two dimensions")
+print("The first result should be approximately (49.5, 12.) for both cases")
