diff --git a/comprehensive_test.py b/comprehensive_test.py
new file mode 100644
index 000000000..977bc4dc9
--- /dev/null
+++ b/comprehensive_test.py
@@ -0,0 +1,59 @@
+from astropy.table import Table
+from io import StringIO
+
+# Test 1: Basic functionality from the original issue
+print("=== Test 1: Basic functionality ===")
+t = Table([(1.23875234858e-24, 3.2348748432e-15), (2, 4)], names=('a', 'b'))
+tc = t.copy()
+
+with StringIO() as sp:
+    tc.write(sp, format="html", formats={"a": lambda x: f"{x:.2e}"})
+    result = sp.getvalue()
+    print("HTML output with format:")
+    print(result)
+    
+    # Check that the format was applied
+    assert "1.24e-24" in result
+    assert "3.23e-15" in result
+    print("✓ Format applied correctly")
+
+# Test 2: Multiple formats
+print("\\n=== Test 2: Multiple formats ===")
+t2 = Table([(1.23456789, 2.34567890), (10, 20)], names=('x', 'y'))
+
+with StringIO() as sp:
+    t2.write(sp, format="html", formats={"x": lambda x: f"{x:.3f}", "y": lambda x: f"{x:03d}"})
+    result = sp.getvalue()
+    print("HTML output with multiple formats:")
+    print(result)
+    
+    # Check that both formats were applied
+    assert "1.235" in result  # 3 decimal places
+    assert "010" in result   # 3-digit zero-padded
+    print("✓ Multiple formats applied correctly")
+
+# Test 3: No formats (should work as before)
+print("\\n=== Test 3: No formats ===")
+with StringIO() as sp:
+    tc.write(sp, format="html")
+    result = sp.getvalue()
+    print("HTML output without formats:")
+    print(result)
+    print("✓ Works without formats")
+
+# Test 4: Different format types
+print("\\n=== Test 4: Different format types ===")
+t3 = Table([(1.23456789, 2.34567890), (10, 20)], names=('float_col', 'int_col'))
+
+with StringIO() as sp:
+    t3.write(sp, format="html", formats={"float_col": "{:.2f}", "int_col": "{:04d}"})
+    result = sp.getvalue()
+    print("HTML output with different format types:")
+    print(result)
+    
+    # Check that formats were applied
+    assert "1.23" in result  # 2 decimal places
+    assert "0010" in result  # 4-digit zero-padded
+    print("✓ Different format types applied correctly")
+
+print("\\n=== All tests passed! ===")
