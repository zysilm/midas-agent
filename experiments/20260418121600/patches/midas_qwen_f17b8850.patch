+++ b/reproduce_issue.py
@@ -0,0 +1,81 @@
+import numpy as np
+from astropy.modeling import models as m
+from astropy.modeling.separable import separability_matrix
+
+# Test case from the issue
+print("Testing the issue described:")
+
+# Simple case - should be diagonal
+print("Simple compound model:")
+cm = m.Linear1D(10) & m.Linear1D(5)
+print("Model:", cm)
+print("Separability matrix:")
+print(separability_matrix(cm))
+
+# More complex case - should be diagonal blocks
+print("\\nComplex compound model:")
+cm2 = m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)
+print("Model:", cm2)
+print("Separability matrix:")
+print(separability_matrix(cm2))
+
+# Nested compound model - this is the problematic case
+print("\\nNested compound model:")
+cm3 = m.Pix2Sky_TAN() & cm
+print("Model:", cm3)
+print("Separability matrix:")
+print(separability_matrix(cm3))
+
+# Let's also check the expected vs actual
+print("\\nExpected separability matrix for nested model (diagonal blocks):")
+expected = np.array([[ True,  True, False, False],
+                     [ True,  True, False, False],
+                     [False, False,  True, False],
+                     [False, False, False,  True]])
+print(expected)
+
+print("\\nActual separability matrix:")
+actual = separability_matrix(cm3)
+print(actual)
+
+print("\\nAre they equal?")
+print(np.array_equal(actual, expected))
+
+# Verify the number of inputs and outputs
+print("\\nModel properties:")
+print("cm3.n_inputs:", cm3.n_inputs)
+print("cm3.n_outputs:", cm3.n_outputs)
+print("cm.n_inputs:", cm.n_inputs)
+print("cm.n_outputs:", cm.n_outputs)
+print("Pix2Sky_TAN.n_inputs:", m.Pix2Sky_TAN().n_inputs)
+print("Pix2Sky_TAN.n_outputs:", m.Pix2Sky_TAN().n_outputs)
+print("Linear1D(10).n_inputs:", m.Linear1D(10).n_inputs)
+print("Linear1D(10).n_outputs:", m.Linear1D(10).n_outputs)
+print("Linear1D(5).n_inputs:", m.Linear1D(5).n_inputs)
+print("Linear1D(5).n_outputs:", m.Linear1D(5).n_outputs)
+
+# Check the separability of the nested model components
+print("\\nComponent separability:")
+print("Pix2Sky_TAN().separable:", m.Pix2Sky_TAN().separable)
+print("cm.separable:", cm.separable)
+print("cm3.separable:", cm3.separable)
+
+# Let's see what the _separable function returns for each component
+print("\\nInternal separability matrices:")
+try:
+    print("_separable(Pix2Sky_TAN()):")
+    print(np.array(m.Pix2Sky_TAN()._calculate_separability_matrix()))
+except:
+    print("Pix2Sky_TAN() doesn't have _calculate_separability_matrix")
+    
+try:
+    print("_separable(cm):")
+    print(np.array(cm._calculate_separability_matrix()))
+except:
+    print("cm doesn't have _calculate_separability_matrix")
+    
+try:
+    print("_separable(cm3):")
+    print(np.array(cm3._calculate_separability_matrix()))
+except:
+    print("cm3 doesn't have _calculate_separability_matrix")
