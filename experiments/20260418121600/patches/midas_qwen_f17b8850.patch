+import numpy as np
+from astropy.modeling import models as m
+from astropy.modeling.separable import separability_matrix
+
+# Test the exact case from the issue
+print("=== Issue reproduction ===")
+
+# Simple case - should be diagonal
+print("Simple case:")
+cm = m.Linear1D(10) & m.Linear1D(5)
+print("cm:", cm)
+print("separability_matrix(cm):")
+print(separability_matrix(cm))
+
+# Complex case - should be diagonal blocks
+print("\\nComplex case:")
+cm2 = m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)
+print("cm2:", cm2)
+print("separability_matrix(cm2):")
+print(separability_matrix(cm2))
+
+# Nested case - this is the problem
+print("\\nNested case:")
+cm3 = m.Pix2Sky_TAN() & cm
+print("cm3:", cm3)
+print("separability_matrix(cm3):")
+print(separability_matrix(cm3))
+
+print("\\nExpected for nested case:")
+expected = np.array([[ True,  True, False, False],
+                     [ True,  True, False, False],
+                     [False, False,  True, False],
+                     [False, False, False,  True]])
+print(expected)
+
+print("\\nActual for nested case:")
+actual = separability_matrix(cm3)
+print(actual)
+
+print("\\nAre they equal?")
+print(np.array_equal(actual, expected))
+
+# Let's also test what happens with just the Linear1D models
+print("\\n=== Testing Linear1D models separately ===")
+l1 = m.Linear1D(10)
+l2 = m.Linear1D(5)
+print("l1:", l1)
+print("l2:", l2)
+print("l1.n_inputs:", l1.n_inputs)
+print("l1.n_outputs:", l1.n_outputs)
+print("l2.n_inputs:", l2.n_inputs)
+print("l2.n_outputs:", l2.n_outputs)
