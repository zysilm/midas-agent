+# Test with HADec
+hadec_frame = HADec(location=location, obstime=Time('2026-04-18T12:00:00'))
+hadec_coord = itrs_coord.transform_to(hadec_frame)
+hadec_back = hadec_coord.transform_to(ITRS(obstime=Time('2026-04-18T12:00:00')))
+
+print('\\nTransformed to HADec:', hadec_coord)
+print('Transformed back to ITRS:', hadec_back)
