+import numpy as np
+from astropy import units as u
+from astropy.time import Time
+from astropy.coordinates import EarthLocation, ITRS, AltAz, HADec
+
+# Create a test location (Greenwich)
+location = EarthLocation(lat=51.5074*u.deg, lon=-0.1278*u.deg, height=0*u.m)
+
+# Create an ITRS coordinate (approximate Greenwich position)
+itrs_coord = ITRS(x=4000000*u.m, y=100000*u.m, z=4900000*u.m, obstime=Time('2026-04-18T12:00:00'))
+
+# Transform to AltAz using the current system
+altaz_frame = AltAz(location=location, obstime=Time('2026-04-18T12:00:00'))
+altaz_coord = itrs_coord.transform_to(altaz_frame)
+
+# Transform back to ITRS
+itrs_back = altaz_coord.transform_to(ITRS(obstime=Time('2026-04-18T12:00:00')))
+
+# Print results
+print('Original ITRS:', itrs_coord)
+print('Transformed to AltAz:', altaz_coord)
+print('Transformed back to ITRS:', itrs_back)
