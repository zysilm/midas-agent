+"""
+Contains the transformation functions for getting to "observed" systems from ITRS.
+"""
+import numpy as np
+import erfa
+
+from astropy import units as u
+from astropy.coordinates.baseframe import frame_transform_graph
+from astropy.coordinates.transformations import FunctionTransformWithFiniteDifference
+from astropy.coordinates.representation import (SphericalRepresentation,
+                                                UnitSphericalRepresentation)
+
+from .itrs import ITRS
+from .altaz import AltAz
+from .hadec import HADec
+from .utils import PIOVER2
+from ..erfa_astrom import erfa_astrom
+
+
+@frame_transform_graph.transform(FunctionTransformWithFiniteDifference, ITRS, AltAz)
+@frame_transform_graph.transform(FunctionTransformWithFiniteDifference, ITRS, HADec)
+def itrs_to_observed(itrs_coo, observed_frame):
+    """
+    Transform from ITRS to observed frames (AltAz, HADec).
+    """
+    # If the data are UnitSphericalRepresentation, we can skip the distance calculations
+    is_unitspherical = (isinstance(itrs_coo.data, UnitSphericalRepresentation) or
+                        itrs_coo.cartesian.x.unit == u.one)
+
+    # First, check if the location and obstime need to be updated
+    if (np.any(observed_frame.location != itrs_coo.location) or
+            np.any(itrs_coo.obstime != observed_frame.obstime)):
+        itrs_coo = itrs_coo.transform_to(ITRS(obstime=observed_frame.obstime,
+                                              location=observed_frame.location))
+
+    # Convert ITRS to topocentric coordinates
+    # Get the astrometry context for ITRS->observed
+    astrom = erfa_astrom.get().apio(observed_frame)
+
+    # Get the position in ITRS as a unit vector
+    if is_unitspherical:
+        itrs_srepr = itrs_coo.spherical
+    else:
+        # Convert to spherical representation
+        itrs_srepr = itrs_coo.cartesian.represent_as(SphericalRepresentation)
+
+    # Extract ITRS coordinates
+    lon = itrs_srepr.lon.to_value(u.radian)
+    lat = itrs_srepr.lat.to_value(u.radian)
+    
+    # For ITRS, we need to compute the topocentric position
+    # The ITRS coordinates are already geocentric, so we need to convert to topocentric
+    # using the observer's location and time
+    
+    # Convert ITRS to topocentric CIRS (this is the intermediate step)
+    # We need to transform to CIRS first, then to observed
+    # This is similar to how ICRS->observed works, but using ITRS as input
+    
+    # Create a CIRS frame with the same location and obstime as the ITRS
+    cirs_coo = itrs_coo.transform_to(CIRS(obstime=itrs_coo.obstime, location=itrs_coo.location))
+    
+    # Now transform from CIRS to observed (we can reuse the existing cirs_to_observed)
+    # This avoids duplicating code and leverages the existing transformation
+    return cirs_coo.transform_to(observed_frame)
+
+
+@frame_transform_graph.transform(FunctionTransformWithFiniteDifference, AltAz, ITRS)
+@frame_transform_graph.transform(FunctionTransformWithFiniteDifference, HADec, ITRS)
+def observed_to_itrs(observed_coo, itrs_frame):
+    """
+    Transform from observed frames (AltAz, HADec) to ITRS.
+    """
+    # Convert observed frame to CIRS first (reuse existing transformation)
+    cirs_coo = observed_coo.transform_to(CIRS(obstime=observed_coo.obstime, location=observed_coo.location))
+    
+    # Then transform from CIRS to ITRS
+    return cirs_coo.transform_to(ITRS(obstime=observed_coo.obstime, location=observed_coo.location))
