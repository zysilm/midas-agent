--- /dev/null
+++ b/test_hasattr.py
@@ -0,0 +1,33 @@
+import astropy.coordinates as coord
+
+
+class custom_coord(coord.SkyCoord):
+    @property
+    def prop(self):
+        return self.random_attr
+
+
+c = custom_coord('00h42m30s', '+41d12m00s', frame='icrs')
+
+print("Checking hasattr behavior:")
+print("hasattr(c, 'prop'):", hasattr(c, 'prop'))
+print("hasattr(c, 'random_attr'):", hasattr(c, 'random_attr'))
+
+# Check what's in the instance dict
+print("c.__dict__ keys:", list(c.__dict__.keys()))
+
+# Check what's in the class dict
+print("custom_coord.__dict__ keys:", list(custom_coord.__dict__.keys()))
+print("'prop' in custom_coord.__dict__:", 'prop' in custom_coord.__dict__)
+
+# Check if prop is a property
+prop_desc = custom_coord.__dict__['prop']
+print("prop is property:", isinstance(prop_desc, property))
+
+# Try to get the property from the class
+try:
+    prop = getattr(custom_coord, 'prop')
+    print("Got prop from class:", prop)
+    print("prop type:", type(prop))
+except Exception as e:
+    print("Error getting prop from class:", e)
