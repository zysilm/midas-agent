+import traceback
+import astropy.coordinates as coord
+
+
+class custom_coord(coord.SkyCoord):
+    @property
+    def prop(self):
+        print("Inside prop getter")
+        print("About to access random_attr")
+        return self.random_attr
+
+
+c = custom_coord('00h42m30s', '+41d12m00s', frame='icrs')
+print("Created custom_coord successfully")
+print("Attempting to access prop...")
+
+# Let's manually trace what happens
+print("Checking if _sky_coord_frame is in __dict__:", "_sky_coord_frame" in c.__dict__)
+
+# Let's see what happens when we access random_attr directly
+print("Accessing random_attr directly:")
+try:
+    result = c.random_attr
+    print(f"Direct access result: {result}")
+except Exception as e:
+    print(f"Direct access error: {e}")
+    traceback.print_exc()
+
+print("\\nNow accessing prop:")
+try:
+    result = c.prop
+    print(f"Prop access result: {result}")
+except Exception as e:
+    print(f"Prop access error: {e}")
+    traceback.print_exc()
