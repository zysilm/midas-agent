@@ -0,0 +1,31 @@
+import astropy.coordinates as coord
+
+
+class custom_coord(coord.SkyCoord):
+    @property
+    def prop(self):
+        print("Inside prop getter")
+        return self.random_attr
+
+
+c = custom_coord('00h42m30s', '+41d12m00s', frame='icrs')
+print("Class MRO:", custom_coord.__mro__)
+print("Has prop in class:", hasattr(custom_coord, 'prop'))
+print("Has prop in instance:", hasattr(c, 'prop'))
+
+# Check if prop is in the class dict
+print("prop in custom_coord.__dict__:", 'prop' in custom_coord.__dict__)
+
+# Try to get the property directly
+try:
+    prop_desc = custom_coord.__dict__['prop']
+    print("prop is a property:", isinstance(prop_desc, property))
+except KeyError:
+    print("prop not found in class dict")
+
+# Try to access prop normally
+try:
+    result = c.prop
+    print(f"Direct access result: {result}")
+except AttributeError as e:
+    print(f"Direct access AttributeError: {e}")
