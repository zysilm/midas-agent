new file mode 100644
index 000000000..f140999e1
--- /dev/null
+++ b/test_attribute_resolution.py
@@ -0,0 +1,23 @@
+# Test to understand attribute resolution
+class Base:
+    def __getattr__(self, attr):
+        print(f"Base.__getattr__ called with: {attr}")
+        raise AttributeError(f"Base: {attr} not found")
+
+class Sub(Base):
+    @property
+    def prop(self):
+        print("Sub.prop getter called")
+        return self.random_attr
+
+# Test normal behavior
+print("=== Testing normal behavior ===")
+obj = Sub()
+print("hasattr(obj, 'prop'):", hasattr(obj, 'prop'))
+
+print("\\n=== Now testing what happens ===")
+try:
+    result = obj.prop
+    print("Success:", result)
+except Exception as e:
+    print("Exception:", e)
