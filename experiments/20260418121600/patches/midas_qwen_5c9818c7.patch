@@ -0,0 +1,59 @@
+#!/usr/bin/env python
+
+from astropy.modeling import models as m
+from astropy.modeling.separable import separability_matrix
+
+print("Comprehensive testing of separability matrix fix...")
+
+# Test 1: Original issue case
+print("Test 1: Original issue case")
+cm = m.Linear1D(10) & m.Linear1D(5)
+complex_cm = m.Pix2Sky_TAN() & cm
+result = separability_matrix(complex_cm)
+print("Result:")
+print(result)
+print("Expected: Last two rows should be [False False  True False] and [False False False  True]")
+print("Correct:", 
+      result[2, 2] == True and result[2, 3] == False and 
+      result[3, 3] == True and result[3, 2] == False)
+print()
+
+# Test 2: Simple nested case
+print("Test 2: Simple nested case")
+nested1 = (m.Linear1D(1) & m.Linear1D(2)) & m.Linear1D(3)
+result2 = separability_matrix(nested1)
+print("Result:")
+print(result2)
+print("Should be diagonal for independent components")
+print("Correct:", 
+      result2[0, 0] == True and result2[1, 1] == True and 
+      result2[2, 2] == True and result2[0, 1] == False and 
+      result2[1, 0] == False and result2[2, 0] == False and result2[2, 1] == False)
+print()
+
+# Test 3: Multiple nesting levels
+print("Test 3: Multiple nesting levels")
+nested2 = m.Pix2Sky_TAN() & (m.Linear1D(10) & m.Linear1D(5))
+result3 = separability_matrix(nested2)
+print("Result:")
+print(result3)
+print("Should match the non-nested version")
+complex_direct = m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)
+expected3 = separability_matrix(complex_direct)
+print("Expected:")
+print(expected3)
+print("Equal:", (result3 == expected3).all())
+print()
+
+# Test 4: Verify simple cases still work
+print("Test 4: Simple cases still work")
+simple1 = m.Linear1D(10) & m.Linear1D(5)
+result4 = separability_matrix(simple1)
+print("Simple case result:")
+print(result4)
+print("Should be diagonal:", 
+      result4[0, 0] == True and result4[1, 1] == True and 
+      result4[0, 1] == False and result4[1, 0] == False)
+print()
+
+print("All tests completed!")
