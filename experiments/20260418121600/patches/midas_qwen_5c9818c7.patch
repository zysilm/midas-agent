+#!/usr/bin/env python
+
+from astropy.modeling import models as m
+from astropy.modeling.separable import separability_matrix
+
+print("Testing separability matrix issue...")
+
+# Simple case - should be diagonal
+cm = m.Linear1D(10) & m.Linear1D(5)
+print("cm = m.Linear1D(10) & m.Linear1D(5)")
+print("separability_matrix(cm):")
+print(separability_matrix(cm))
+print()
+
+# More complex case
+print("m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)")
+complex_cm = m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)
+print("separability_matrix(complex_cm):")
+print(separability_matrix(complex_cm))
+print()
+
+# Nested case - this is where the bug occurs
+print("m.Pix2Sky_TAN() & cm")
+nested_cm = m.Pix2Sky_TAN() & cm
+print("separability_matrix(nested_cm):")
+print(separability_matrix(nested_cm))
+print()
+
+# Let's also check the individual components
+print("cm.n_inputs, cm.n_outputs:", cm.n_inputs, cm.n_outputs)
+print("complex_cm.n_inputs, complex_cm.n_outputs:", complex_cm.n_inputs, complex_cm.n_outputs)
+print("nested_cm.n_inputs, nested_cm.n_outputs:", nested_cm.n_inputs, nested_cm.n_outputs)
