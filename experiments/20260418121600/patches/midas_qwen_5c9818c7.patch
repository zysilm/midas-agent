+#!/usr/bin/env python
+
+from astropy.modeling import models as m
+from astropy.modeling.separable import separability_matrix, _separable, _cstack, _coord_matrix
+import numpy as np
+
+print("Detailed debugging of separability_matrix issue...")
+
+# Create models
+cm = m.Linear1D(10) & m.Linear1D(5)
+pix2sky = m.Pix2Sky_TAN()
+
+print("cm = m.Linear1D(10) & m.Linear1D(5)")
+print("cm.n_inputs:", cm.n_inputs)
+print("cm.n_outputs:", cm.n_outputs)
+print("_separable(cm):")
+print(_separable(cm))
+print()
+
+print("pix2sky = m.Pix2Sky_TAN()")
+print("pix2sky.n_inputs:", pix2sky.n_inputs)
+print("pix2sky.n_outputs:", pix2sky.n_outputs)
+print("_separable(pix2sky):")
+print(_separable(pix2sky))
+print()
+
+print("complex_cm = pix2sky & cm")
+complex_cm = pix2sky & cm
+print("complex_cm.n_inputs:", complex_cm.n_inputs)
+print("complex_cm.n_outputs:", complex_cm.n_outputs)
+print("separability_matrix(complex_cm):")
+print(separability_matrix(complex_cm))
+print()
+
+# Let's trace through the _separable execution
+print("Tracing _separable for complex_cm:")
+print("complex_cm.op:", complex_cm.op)
+print("complex_cm.left:", complex_cm.left)
+print("complex_cm.right:", complex_cm.right)
+
+sepleft = _separable(complex_cm.left)
+print("_separable(complex_cm.left):")
+print(sepleft)
+
+sepright = _separable(complex_cm.right)
+print("_separable(complex_cm.right):")
+print(sepright)
+
+print("_operators['&'](sepleft, sepright):")
+result = _cstack(sepleft, sepright)
+print(result)
+
+# Now let's see what happens when we do it as a single compound model
+print("\\nDirectly calling _cstack with the matrices:")
+coord_left = _coord_matrix(complex_cm.left, 'left', complex_cm.n_outputs)
+print("_coord_matrix(complex_cm.left, 'left', 4):")
+print(coord_left)
+
+coord_right = _coord_matrix(complex_cm.right, 'right', complex_cm.n_outputs)
+print("_coord_matrix(complex_cm.right, 'right', 4):")
+print(coord_right)
+
+print("np.hstack([coord_left, coord_right]):")
+print(np.hstack([coord_left, coord_right]))
