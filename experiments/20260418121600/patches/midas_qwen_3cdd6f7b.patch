+#!/usr/bin/env python
+"""
+Test script to verify the ITRS to Observed transforms work correctly.
+"""
+
+import numpy as np
+from astropy import units as u
+from astropy.coordinates import ITRS, AltAz, HADec, EarthLocation
+from astropy.time import Time
+
+def test_itrs_to_altaz():
+    """Test ITRS to AltAz transformation."""
+    print("=== Testing ITRS to AltAz ===")
+    
+    # Create a test location (e.g., at Greenwich)
+    location = EarthLocation(lat=51.4769*u.deg, lon=0.0005*u.deg, height=0*u.m)
+    
+    # Create an ITRS coordinate at that location (straight overhead for geocentric observer)
+    t = Time('J2010')
+    itrs_coord = location.get_itrs(t)
+    
+    print(f"ITRS coordinate: {itrs_coord}")
+    
+    # Transform to AltAz
+    altaz_frame = AltAz(location=location, obstime=t)
+    altaz_coord = itrs_coord.transform_to(altaz_frame)
+    print(f"AltAz coordinate: {altaz_coord}")
+    print(f"AltAz altitude: {altaz_coord.alt}")
+    print(f"AltAz azimuth: {altaz_coord.az}")
+    
+    # Test round-trip
+    itrs_back = altaz_coord.transform_to(ITRS(obstime=t))
+    print(f"Round-trip ITRS: {itrs_back}")
+    print(f"Position difference: {np.linalg.norm(itrs_coord.cartesian.xyz - itrs_back.cartesian.xyz)}")
+
+def test_itrs_to_hadec():
+    """Test ITRS to HADec transformation."""
+    print("\\n=== Testing ITRS to HADec ===")
+    
+    # Create a test location (e.g., at Greenwich)
+    location = EarthLocation(lat=51.4769*u.deg, lon=0.0005*u.deg, height=0*u.m)
+    
+    # Create an ITRS coordinate at that location
+    t = Time('J2010')
+    itrs_coord = location.get_itrs(t)
+    
+    print(f"ITRS coordinate: {itrs_coord}")
+    
+    # Transform to HADec
+    hadec_frame = HADec(location=location, obstime=t)
+    hadec_coord = itrs_coord.transform_to(hadec_frame)
+    print(f"HADec coordinate: {hadec_coord}")
+    print(f"HADec declination: {hadec_coord.dec}")
+    print(f"HADec hour angle: {hadec_coord.ha}")
+    
+    # Test round-trip
+    itrs_back = hadec_coord.transform_to(ITRS(obstime=t))
+    print(f"Round-trip ITRS: {itrs_back}")
+    print(f"Position difference: {np.linalg.norm(itrs_coord.cartesian.xyz - itrs_back.cartesian.xyz)}")
+
+def test_straight_overhead():
+    """Test the specific case from the issue."""
+    print("\\n=== Testing Straight Overhead Case ===")
+    
+    t = Time('J2010')
+    obj = EarthLocation(-1*u.deg, 52*u.deg, height=10.*u.km)
+    home = EarthLocation(-1*u.deg, 52*u.deg, height=0.*u.km)
+
+    # Create ITRS coordinate at object location
+    obj_itrs = obj.get_itrs(t)
+    
+    # Transform to AltAz using our new approach
+    altaz_frame = AltAz(location=home, obstime=t)
+    altaz_coord = obj_itrs.transform_to(altaz_frame)
+    print(f"AltAz from ITRS: {altaz_coord}")
+    print(f"Altitude: {altaz_coord.alt}")
+    
+    # Transform to HADec using our new approach
+    hadec_frame = HADec(location=home, obstime=t)
+    hadec_coord = obj_itrs.transform_to(hadec_frame)
+    print(f"HADec from ITRS: {hadec_coord}")
+    print(f"Declination: {hadec_coord.dec}")
+    print(f"Hour angle: {hadec_coord.ha}")
+
+if __name__ == "__main__":
+    test_itrs_to_altaz()
+    test_itrs_to_hadec()
+    test_straight_overhead()
