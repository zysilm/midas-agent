+#!/usr/bin/env python
+"""
+Debug script to understand current transformation paths.
+"""
+
+from astropy import units as u
+from astropy.coordinates import ITRS, AltAz, HADec, EarthLocation, CIRS, GCRS
+from astropy.time import Time
+from astropy.coordinates.baseframe import frame_transform_graph
+
+def find_transform_path():
+    """Find the transformation path from ITRS to AltAz."""
+    print("=== Finding Transformation Path ===")
+    
+    try:
+        print("Checking if there are direct transforms...")
+        print(f"ITRS -> AltAz: {ITRS in frame_transform_graph._graph and AltAz in frame_transform_graph._graph[ITRS]}")
+        print(f"AltAz -> ITRS: {AltAz in frame_transform_graph._graph and ITRS in frame_transform_graph._graph[AltAz]}")
+        
+        print("\\nTrying to find shortest path...")
+        path = frame_transform_graph.find_shortest_path(ITRS, AltAz)
+        print("Path from ITRS to AltAz:")
+        for i, frame in enumerate(path):
+            print(f"  {i}: {frame.__name__}")
+        
+        print("\\nPath from AltAz to ITRS:")
+        path = frame_transform_graph.find_shortest_path(AltAz, ITRS)
+        for i, frame in enumerate(path):
+            print(f"  {i}: {frame.__name__}")
+        
+        print("\\nPath from ITRS to HADec:")
+        path = frame_transform_graph.find_shortest_path(ITRS, HADec)
+        for i, frame in enumerate(path):
+            print(f"  {i}: {frame.__name__}")
+        
+        print("\\nPath from HADec to ITRS:")
+        path = frame_transform_graph.find_shortest_path(HADec, ITRS)
+        for i, frame in enumerate(path):
+            print(f"  {i}: {frame.__name__}")
+    except Exception as e:
+        print(f"Error finding path: {e}")
+        import traceback
+        traceback.print_exc()
+
+def test_simple_transform():
+    """Test a simple transform to see what happens."""
+    print("\\n=== Testing Simple Transform ===")
+    
+    # Create a test location (e.g., at Greenwich)
+    location = EarthLocation(lat=51.4769*u.deg, lon=0.0005*u.deg, height=0*u.m)
+    
+    # Create an ITRS coordinate at that location (straight overhead for geocentric observer)
+    t = Time('J2010')
+    itrs_coord = location.get_itrs(t)
+    
+    print(f"ITRS coordinate: {itrs_coord}")
+    
+    # Transform to AltAz
+    altaz_frame = AltAz(location=location, obstime=t)
+    try:
+        altaz_coord = itrs_coord.transform_to(altaz_frame)
+        print(f"AltAz coordinate: {altaz_coord}")
+        print(f"AltAz altitude: {altaz_coord.alt}")
+    except Exception as e:
+        print(f"Error in AltAz transform: {e}")
+        import traceback
+        traceback.print_exc()
+
+if __name__ == "__main__":
+    find_transform_path()
+    test_simple_transform()
