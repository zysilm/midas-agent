+#!/usr/bin/env python
+"""
+Reproduction script for ITRS to Observed transformations issue.
+This script demonstrates the problem with current ITRS to AltAz/HADec transforms.
+"""
+
+import numpy as np
+from astropy import units as u
+from astropy.coordinates import ITRS, AltAz, HADec, EarthLocation, CIRS
+from astropy.time import Time
+
+def test_current_behavior():
+    """Test current behavior to understand the issue."""
+    print("=== Testing Current ITRS to Observed Transformations ===")
+    
+    # Create a test location (e.g., at Greenwich)
+    location = EarthLocation(lat=51.4769*u.deg, lon=0.0005*u.deg, height=0*u.m)
+    
+    # Create an ITRS coordinate at that location (straight overhead for geocentric observer)
+    t = Time('J2010')
+    itrs_coord = location.get_itrs(t)
+    
+    print(f"ITRS coordinate at location: {itrs_coord}")
+    print(f"ITRS coordinate position: {itrs_coord.cartesian}")
+    
+    # Transform to AltAz
+    altaz_frame = AltAz(location=location, obstime=t)
+    try:
+        altaz_coord = itrs_coord.transform_to(altaz_frame)
+        print(f"AltAz coordinate: {altaz_coord}")
+        print(f"AltAz altitude: {altaz_coord.alt}")
+    except Exception as e:
+        print(f"Error in AltAz transform: {e}")
+    
+    # Transform to HADec
+    hadec_frame = HADec(location=location, obstime=t)
+    try:
+        hadec_coord = itrs_coord.transform_to(hadec_frame)
+        print(f"HADec coordinate: {hadec_coord}")
+        print(f"HADec declination: {hadec_coord.dec}")
+        print(f"HADec hour angle: {hadec_coord.ha}")
+    except Exception as e:
+        print(f"Error in HADec transform: {e}")
+
+def test_problematic_case():
+    """Test the specific case mentioned in the issue."""
+    print("\\\\\\\\n=== Testing Problematic Case (Straight Overhead) ===")
+    
+    t = Time('J2010')
+    obj = EarthLocation(-1*u.deg, 52*u.deg, height=10.*u.km)
+    home = EarthLocation(-1*u.deg, 52*u.deg, height=0.*u.km)
+
+    # An object that appears straight overhead - FOR A GEOCENTRIC OBSERVER.
+    # Note, this won't be overhead for a topocentric observer because of
+    # aberration.
+    cirs_geo = obj.get_itrs(t).transform_to(CIRS(obstime=t))
+
+    # now get the Geocentric CIRS position of observatory
+    obsrepr = home.get_itrs(t).transform_to(CIRS(obstime=t)).cartesian
+
+    # topocentric CIRS position of a straight overhead object
+    cirs_repr = cirs_geo.cartesian - obsrepr
+
+    # create a CIRS object that appears straight overhead for a TOPOCENTRIC OBSERVER
+    topocentric_cirs_frame = CIRS(obstime=t, location=home)
+    cirs_topo = topocentric_cirs_frame.realize_frame(cirs_repr)
+
+    # Check AltAz (though Azimuth can be anything so is not tested).
+    aa = cirs_topo.transform_to(AltAz(obstime=t, location=home))
+    print(f"Altitude when assuming CIRS: {aa.alt}")
+    
+    # Check HADec.
+    hd = cirs_topo.transform_to(HADec(obstime=t, location=home))
+    print(f"Declination when assuming CIRS: {hd.dec}")
+    print(f"Hour angle when assuming CIRS: {hd.ha}")
+    
+    print("\\\\nThis demonstrates the complexity of the current approach.")
+    print("The issue wants to stay within ITRS and treat ITRS positions as time-invariant.")
+
+if __name__ == "__main__":
+    test_current_behavior()
+    test_problematic_case()
