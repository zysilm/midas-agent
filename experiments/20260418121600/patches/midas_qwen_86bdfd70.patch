+#!/usr/bin/env python
+"""Final test to confirm the fix works"""
+
+from astropy.table import Table
+from io import StringIO
+
+# Test the exact example from the issue
+t = Table([(1.23875234858e-24, 3.2348748432e-15), (2, 4)], names=('a', 'b'))
+tc = t.copy()  # copy table
+
+# print HTML table with "a" column formatted to show 2 decimal places
+with StringIO() as sp:
+    tc.write(sp, format="html", formats={"a": lambda x: f"{x:.2e}"})
+    html_output = sp.getvalue()
+    print(html_output)
+
+# Verify it contains the formatted values
+if "1.24e-24" in html_output and "3.23e-15" in html_output:
+    print("SUCCESS: HTML format now respects the formats parameter!")
+else:
+    print("FAILURE: HTML format still ignores the formats parameter")
