+import numpy as np
+from astropy.time import Time
+from astropy.timeseries import TimeSeries
+
+print("=== Final test of the fix ===")
+
+# Reproduce the exact example from the issue
+print("1. Reproducing the exact issue example:")
+try:
+    time=Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data = {"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["time", "flux"]                                   
+    ts.remove_column("flux")
+except ValueError as e:
+    print(f"Error message: {e}")
+    print("✓ Error message is now clear and informative!")
+
+print("\\n2. Testing that normal operations still work:")
+try:
+    time=Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data = {"flux": [99.9, 99.8, 99.7]})
+    # This should work fine
+    ts.add_column([1, 2, 3], name='extra')
+    print("✓ Adding columns works")
+    
+    # This should also work
+    ts.remove_column('extra') 
+    print("✓ Removing columns works")
+    
+except Exception as e:
+    print(f"Unexpected error: {e}")
+
+print("\\n3. Testing with more required columns:")
+try:
+    time=Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data = {"flux": [99.9, 99.8, 99.7], "magnitude": [5.0, 5.1, 5.2]})
+    ts._required_columns = ["time", "flux", "magnitude"]
+    ts.remove_column("flux")
+except ValueError as e:
+    print(f"Error message: {e}")
+    print("✓ Error message is clear about missing 'flux' column!")
+
+print("\\n=== All tests completed successfully ===")
