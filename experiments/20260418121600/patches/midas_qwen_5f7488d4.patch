+#!/usr/bin/env python
+"""
+Debug script to understand the exact error condition.
+"""
+
+import numpy as np
+from astropy.time import Time
+from astropy.timeseries import TimeSeries
+
+def debug_issue():
+    print("Debugging the TimeSeries issue...")
+    
+    # Create a TimeSeries with time and flux data
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    
+    print(f"Initial columns: {ts.colnames}")
+    print(f"Initial required columns: {ts._required_columns}")
+    
+    # Set additional required columns beyond time
+    ts._required_columns = ["time", "flux"]
+    print(f"Updated required columns: {ts._required_columns}")
+    
+    # Check what happens with the check before removal
+    print("Before removal:")
+    try:
+        ts._check_required_columns()
+        print("  Check passed")
+    except ValueError as e:
+        print(f"  Check failed: {e}")
+    
+    # Remove the flux column
+    ts.remove_column("flux")
+    print(f"After removing flux: {ts.colnames}")
+    
+    # Check what happens with the check after removal
+    print("After removal:")
+    try:
+        ts._check_required_columns()
+        print("  Check passed")
+    except ValueError as e:
+        print(f"  Check failed: {e}")
+        print(f"  Error type: {type(e)}")
+
+if __name__ == "__main__":
+    debug_issue()
