+#!/usr/bin/env python
+"""
+Test edge cases for the TimeSeries fix.
+"""
+
+import numpy as np
+from astropy.time import Time
+from astropy.timeseries import TimeSeries
+
+def test_single_missing_column():
+    """Test when one required column is missing."""
+    print("Testing single missing column...")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["time", "flux"]
+    
+    try:
+        ts.remove_column("flux")
+        print("ERROR: Should have failed")
+    except ValueError as e:
+        print(f"Success: {e}")
+
+def test_multiple_missing_columns():
+    """Test when multiple required columns are missing."""
+    print("\\nTesting multiple missing columns...")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7], "magnitude": [1.0, 2.0, 3.0]})
+    ts._required_columns = ["time", "flux", "magnitude"]
+    
+    # Remove two columns
+    try:
+        ts.remove_column("flux")
+        print("ERROR: Should have failed")
+    except ValueError as e:
+        print(f"Success: {e}")
+    
+    try:
+        ts.remove_column("magnitude")
+        print("ERROR: Should have failed")
+    except ValueError as e:
+        print(f"Success: {e}")
+
+def test_wrong_order():
+    """Test when columns are in wrong order (should still trigger original error)."""
+    print("\\nTesting wrong column order...")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["flux", "time"]  # Wrong order
+    
+    try:
+        ts._check_required_columns()
+        print("ERROR: Should have failed")
+    except ValueError as e:
+        print(f"Success (wrong order): {e}")
+
+def test_empty_series():
+    """Test empty series."""
+    print("\\nTesting empty series...")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["time", "flux"]
+    
+    # Remove all columns
+    try:
+        ts.remove_columns(["time", "flux"])
+        ts._check_required_columns()
+        print("ERROR: Should have failed")
+    except ValueError as e:
+        print(f"Success: {e}")
+
+if __name__ == "__main__":
+    test_single_missing_column()
+    test_multiple_missing_columns()
+    test_wrong_order()
+    test_empty_series()
