+#!/usr/bin/env python
+"""
+Final comprehensive test to make sure our fix works correctly.
+"""
+
+import numpy as np
+from astropy.time import Time
+from astropy.timeseries import TimeSeries
+from astropy.table import Table
+
+def test_original_issue():
+    """Test the exact case from the issue report."""
+    print("=== Testing Original Issue ===")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["time", "flux"]                                   
+    
+    try:
+        ts.remove_column("flux")
+        print("ERROR: Should have failed!")
+        return False
+    except ValueError as e:
+        error_msg = str(e)
+        print(f"Error message: {error_msg}")
+        # Should contain "missing required columns" not the misleading message
+        if "missing required columns" in error_msg:
+            print("✓ PASS: Clear error message")
+            return True
+        else:
+            print("✗ FAIL: Still has misleading message")
+            return False
+
+def test_normal_operation():
+    """Test that normal operations still work."""
+    print("\\n=== Testing Normal Operations ===")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    
+    # This should work fine
+    try:
+        ts.remove_column("flux")
+        print("✓ PASS: remove_column works when not required")
+        return True
+    except Exception as e:
+        print(f"✗ FAIL: Normal operation failed: {e}")
+        return False
+
+def test_wrong_order_still_works():
+    """Test that wrong column order still gives appropriate error."""
+    print("\\n=== Testing Wrong Column Order ===")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["flux", "time"]  # Wrong order
+    
+    try:
+        ts._check_required_columns()
+        print("ERROR: Should have failed!")
+        return False
+    except ValueError as e:
+        error_msg = str(e)
+        print(f"Error message: {error_msg}")
+        # Should still show the original behavior for wrong order
+        if "expected" in error_msg and "but found" in error_msg:
+            print("✓ PASS: Wrong order error still works")
+            return True
+        else:
+            print("✗ FAIL: Wrong order error changed unexpectedly")
+            return False
+
+def test_empty_series():
+    """Test empty series error."""
+    print("\\n=== Testing Empty Series ===")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["time", "flux"]
+    
+    try:
+        ts.remove_columns(["time", "flux"])
+        ts._check_required_columns()
+        print("ERROR: Should have failed!")
+        return False
+    except ValueError as e:
+        error_msg = str(e)
+        print(f"Error message: {error_msg}")
+        # Should still show the original behavior for empty series
+        if "time series has no columns" in error_msg:
+            print("✓ PASS: Empty series error still works")
+            return True
+        else:
+            print("✗ FAIL: Empty series error changed unexpectedly")
+            return False
+
+if __name__ == "__main__":
+    results = []
+    results.append(test_original_issue())
+    results.append(test_normal_operation())
+    results.append(test_wrong_order_still_works())
+    results.append(test_empty_series())
+    
+    print(f"\\n=== SUMMARY ===")
+    print(f"Tests passed: {sum(results)}/{len(results)}")
+    
+    if all(results):
+        print("✓ ALL TESTS PASSED")
+    else:
+        print("✗ SOME TESTS FAILED")
