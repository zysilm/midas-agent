+#!/usr/bin/env python3
+"""
+Comprehensive test for the Quantity.__array_ufunc__ fix.
+"""
+
+import dataclasses
+import numpy as np
+import astropy.units as u
+
+
+@dataclasses.dataclass
+class DuckArray(np.lib.mixins.NDArrayOperatorsMixin):
+    ndarray: u.Quantity
+
+    @property
+    def unit(self) -> u.UnitBase:
+        return self.ndarray.unit
+
+    def __array_ufunc__(self, function, method, *inputs, **kwargs):
+        inputs = [inp.ndarray if isinstance(inp, DuckArray) else inp for inp in inputs]
+
+        for inp in inputs:
+            if isinstance(inp, np.ndarray):
+                result = inp.__array_ufunc__(function, method, *inputs, **kwargs)
+                if result is not NotImplemented:
+                    return DuckArray(result)
+
+        return NotImplemented
+
+
+def test_comprehensive():
+    print("Running comprehensive tests...")
+    
+    # Test 1: Basic operations that should work
+    print("Test 1: Basic Quantity operations")
+    try:
+        q1 = 5 * u.m
+        q2 = 3 * u.m
+        result = q1 + q2
+        print(f"  {q1} + {q2} = {result}")
+    except Exception as e:
+        print(f"  Error: {e}")
+    
+    # Test 2: DuckArray with compatible units
+    print("Test 2: DuckArray with compatible units")
+    try:
+        result = DuckArray(1 * u.mm) + (1 * u.m)
+        print(f"  DuckArray(1 * u.mm) + (1 * u.m) = {result}")
+    except Exception as e:
+        print(f"  Error: {e}")
+    
+    # Test 3: DuckArray with same units
+    print("Test 3: DuckArray with same units")
+    try:
+        result = (1 * u.mm) + DuckArray(1 * u.mm)
+        print(f"  (1 * u.mm) + DuckArray(1 * u.mm) = {result}")
+    except Exception as e:
+        print(f"  Error: {e}")
+    
+    # Test 4: DuckArray with different units (the main issue)
+    print("Test 4: DuckArray with different units (main issue)")
+    try:
+        result = (1 * u.m) + DuckArray(1 * u.mm)
+        print(f"  (1 * u.m) + DuckArray(1 * u.mm) = {result}")
+    except Exception as e:
+        print(f"  Error: {e}")
+    
+    # Test 5: Other operations
+    print("Test 5: Other operations with DuckArray")
+    try:
+        result = (1 * u.m) * DuckArray(2 * u.mm)
+        print(f"  (1 * u.m) * DuckArray(2 * u.mm) = {result}")
+    except Exception as e:
+        print(f"  Error: {e}")
+    
+    # Test 6: Reverse operations
+    print("Test 6: Reverse operations")
+    try:
+        result = DuckArray(2 * u.mm) * (1 * u.m)
+        print(f"  DuckArray(2 * u.mm) * (1 * u.m) = {result}")
+    except Exception as e:
+        print(f"  Error: {e}")
+    
+    # Test 7: Operations that should still raise errors
+    print("Test 7: Operations that should still raise errors")
+    try:
+        result = (1 * u.m) + (1 * u.s)  # incompatible units
+        print(f"  (1 * u.m) + (1 * u.s) = {result}")
+    except Exception as e:
+        print(f"  Expected error: {type(e).__name__}: {e}")
+    
+    print("All tests completed.")
+
+
+if __name__ == "__main__":
+    test_comprehensive()
