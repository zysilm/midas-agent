+#!/usr/bin/env python3
+"""
+Edge case tests for the Quantity.__array_ufunc__ fix.
+"""
+
+import dataclasses
+import numpy as np
+import astropy.units as u
+
+
+@dataclasses.dataclass
+class DuckArray(np.lib.mixins.NDArrayOperatorsMixin):
+    ndarray: u.Quantity
+
+    @property
+    def unit(self) -> u.UnitBase:
+        return self.ndarray.unit
+
+    def __array_ufunc__(self, function, method, *inputs, **kwargs):
+        inputs = [inp.ndarray if isinstance(inp, DuckArray) else inp for inp in inputs]
+
+        for inp in inputs:
+            if isinstance(inp, np.ndarray):
+                result = inp.__array_ufunc__(function, method, *inputs, **kwargs)
+                if result is not NotImplemented:
+                    return DuckArray(result)
+
+        return NotImplemented
+
+
+def test_edge_cases():
+    print("Testing edge cases...")
+    
+    # Test 1: Multiple incompatible operands
+    print("Test 1: Multiple incompatible operands")
+    try:
+        result = (1 * u.m) + DuckArray(1 * u.mm) + (2 * u.m)
+        print(f"  Result: {result}")
+    except Exception as e:
+        print(f"  Error: {e}")
+    
+    # Test 2: Incompatible operation that should still fail
+    print("Test 2: Incompatible units that should fail")
+    try:
+        result = (1 * u.m) + (1 * u.s)  # time and length
+        print(f"  Unexpected success: {result}")
+    except Exception as e:
+        print(f"  Expected error: {type(e).__name__}: {e}")
+    
+    # Test 3: DuckArray with different operations
+    print("Test 3: DuckArray with different operations")
+    try:
+        result = (1 * u.m) * DuckArray(2 * u.mm)
+        print(f"  Multiplication: {result}")
+    except Exception as e:
+        print(f"  Error: {e}")
+    
+    # Test 4: Reverse operations
+    print("Test 4: Reverse operations")
+    try:
+        result = DuckArray(2 * u.mm) * (1 * u.m)
+        print(f"  Reverse multiplication: {result}")
+    except Exception as e:
+        print(f"  Error: {e}")
+    
+    # Test 5: Comparison operations
+    print("Test 5: Comparison operations")
+    try:
+        result = (1 * u.m) > DuckArray(500 * u.mm)
+        print(f"  Comparison: {result}")
+    except Exception as e:
+        print(f"  Error: {e}")
+    
+    print("Edge case tests completed.")
+
+
+if __name__ == "__main__":
+    test_edge_cases()
