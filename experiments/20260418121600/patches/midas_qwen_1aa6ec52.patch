+#!/usr/bin/env python
+"""
+Reproduction script for separability_matrix issue with nested CompoundModels
+"""
+
+from astropy.modeling import models as m
+from astropy.modeling.separable import separability_matrix
+
+print("Testing separability_matrix with nested CompoundModels")
+print("=" * 60)
+
+# Create the basic models
+cm = m.Linear1D(10) & m.Linear1D(5)
+print("cm = m.Linear1D(10) & m.Linear1D(5)")
+print("separability_matrix(cm):")
+result1 = separability_matrix(cm)
+print(result1)
+print()
+
+# More complex model
+print("m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)")
+complex_model = m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)
+print("separability_matrix(complex_model):")
+result2 = separability_matrix(complex_model)
+print(result2)
+print()
+
+# Nested model - this is where the issue occurs
+print("m.Pix2Sky_TAN() & cm")
+nested_model = m.Pix2Sky_TAN() & cm
+print("separability_matrix(nested_model):")
+result3 = separability_matrix(nested_model)
+print(result3)
+print()
+
+# Let's also check the shapes
+print("Shapes:")
+print(f"cm.n_inputs: {cm.n_inputs}, cm.n_outputs: {cm.n_outputs}")
+print(f"complex_model.n_inputs: {complex_model.n_inputs}, complex_model.n_outputs: {complex_model.n_outputs}")
+print(f"nested_model.n_inputs: {nested_model.n_inputs}, nested_model.n_outputs: {nested_model.n_outputs}")
+print()
+
+# Let's also test what the expected result should be
+print("Expected behavior analysis:")
+print("The nested model should behave the same as the complex_model")
+print("Both should have separable inputs/outputs in the same pattern")
+print("Expected result should be similar to complex_model result:")
+print(result2)
+print()
+
+# Let's also check the individual components
+print("Individual components:")
+print("m.Pix2Sky_TAN().n_inputs:", m.Pix2Sky_TAN().n_inputs)
+print("m.Pix2Sky_TAN().n_outputs:", m.Pix2Sky_TAN().n_outputs)
+print("cm.n_inputs:", cm.n_inputs)
+print("cm.n_outputs:", cm.n_outputs)
