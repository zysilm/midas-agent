+#!/usr/bin/env python
+"""
+Comprehensive test to verify the fix for separability_matrix issue with nested CompoundModels
+"""
+
+from astropy.modeling import models as m
+from astropy.modeling.separable import separability_matrix
+
+def test_nested_compound_models():
+    """Test the specific issue reported in the bug"""
+    
+    # Create the basic models
+    cm = m.Linear1D(10) & m.Linear1D(5)
+    
+    # This should work correctly (and did before)
+    result1 = separability_matrix(cm)
+    print("cm = m.Linear1D(10) & m.Linear1D(5)")
+    print("separability_matrix(cm):")
+    print(result1)
+    print()
+    
+    # More complex model (this should work correctly)
+    complex_model = m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)
+    result2 = separability_matrix(complex_model)
+    print("m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)")
+    print("separability_matrix(complex_model):")
+    print(result2)
+    print()
+    
+    # The problematic nested model - this is what we're fixing
+    nested_model = m.Pix2Sky_TAN() & cm
+    result3 = separability_matrix(nested_model)
+    print("m.Pix2Sky_TAN() & cm")
+    print("separability_matrix(nested_model):")
+    print(result3)
+    print()
+    
+    # Verify they are the same
+    print("Are complex_model and nested_model results identical?")
+    are_equal = (result2 == result3).all()
+    print(are_equal)
+    
+    if are_equal:
+        print("✓ SUCCESS: Nested CompoundModel now works correctly!")
+    else:
+        print("✗ FAILURE: Results still differ")
+        print("Expected (complex_model):")
+        print(result2)
+        print("Actual (nested_model):")
+        print(result3)
+        
+    return are_equal
+
+def test_additional_cases():
+    """Test additional edge cases"""
+    
+    print("\\n=== Additional Test Cases ===")
+    
+    # Test with different compound models
+    model1 = m.Linear1D(2) & m.Shift(1) & m.Scale(3)
+    result1 = separability_matrix(model1)
+    print("Linear1D(2) & Shift(1) & Scale(3):")
+    print(result1)
+    
+    # Test nested version
+    nested1 = m.Linear1D(2) & (m.Shift(1) & m.Scale(3))
+    result2 = separability_matrix(nested1)
+    print("Linear1D(2) & (Shift(1) & Scale(3)):")
+    print(result2)
+    
+    print("Are these results identical?")
+    print((result1 == result2).all())
+    
+    return True
+
+if __name__ == "__main__":
+    success = test_nested_compound_models()
+    test_additional_cases()
+    
+    if success:
+        print("\\n🎉 All tests passed! The fix is working correctly.")
+    else:
+        print("\\n❌ Some tests failed.")
+        exit(1)
