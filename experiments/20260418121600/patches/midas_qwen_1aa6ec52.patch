+#!/usr/bin/env python
+"""
+Debug script for separability_matrix issue
+"""
+
+import numpy as np
+from astropy.modeling import models as m
+from astropy.modeling.separable import _separable, _cstack, _coord_matrix, separability_matrix
+
+print("=== Detailed Debug of Separability Issue ===")
+
+# Create the models
+cm = m.Linear1D(10) & m.Linear1D(5)
+complex_model = m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)
+nested_model = m.Pix2Sky_TAN() & cm
+
+print("cm = Linear1D(10) & Linear1D(5)")
+print("complex_model = Pix2Sky_TAN() & Linear1D(10) & Linear1D(5)")
+print("nested_model = Pix2Sky_TAN() & cm")
+
+print("\\n=== Testing separability_matrix directly ===")
+print("separability_matrix(complex_model):")
+result_complex = separability_matrix(complex_model)
+print(result_complex)
+
+print("\\nseparability_matrix(nested_model):")
+result_nested = separability_matrix(nested_model)
+print(result_nested)
+
+print("\\n=== Expected result ===")
+print("Should be same as complex_model:")
+print(result_complex)
+
+print("\\n=== Manual tracing of _separable ===")
+print("nested_model.left:", type(nested_model.left))
+print("nested_model.right:", type(nested_model.right))
+
+# Get separability of components
+sepleft = _separable(nested_model.left)
+sepright = _separable(nested_model.right)
+
+print("\\nsepleft (left component):")
+print(sepleft)
+print("sepright (right component):")
+print(sepright)
+
+print("\\n=== Testing _cstack directly ===")
+try:
+    cstack_result = _cstack(sepleft, sepright)
+    print("_cstack(sepleft, sepright):")
+    print(cstack_result)
+except Exception as e:
+    print("Error in _cstack:", e)
+    import traceback
+    traceback.print_exc()
+
+print("\\n=== Testing _coord_matrix on right component ===")
+try:
+    right_coord = _coord_matrix(nested_model.right, 'right', nested_model.n_outputs)
+    print("_coord_matrix(nested_model.right, 'right', nested_model.n_outputs):")
+    print(right_coord)
+except Exception as e:
+    print("Error in _coord_matrix:", e)
+    import traceback
+    traceback.print_exc()
+
+print("\\n=== Testing _coord_matrix on left component ===")
+try:
+    left_coord = _coord_matrix(nested_model.left, 'left', nested_model.n_outputs)
+    print("_coord_matrix(nested_model.left, 'left', nested_model.n_outputs):")
+    print(left_coord)
+except Exception as e:
+    print("Error in _coord_matrix:", e)
+    import traceback
+    traceback.print_exc()
