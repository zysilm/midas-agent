diff --git a/debug_detailed.py b/debug_detailed.py
new file mode 100644
index 000000000..b2d27787d
--- /dev/null
+++ b/debug_detailed.py
@@ -0,0 +1,44 @@
+from astropy.table import Table
+from io import StringIO
+
+# Monkey patch to add debugging
+original_write = None
+
+def debug_write(self, table):
+    print("DEBUG: HTML.write() called")
+    print(f"DEBUG: self.formats = {self.formats}")
+    
+    # Check if formats is set
+    if 'formats' in self.formats:
+        print(f"DEBUG: formats parameter found: {self.formats['formats']}")
+    
+    # Check the data object
+    print(f"DEBUG: self.data.formats = {self.data.formats}")
+    
+    # Check the columns
+    cols = list(table.columns.values())
+    for i, col in enumerate(cols):
+        print(f"DEBUG: Column {i} ({col.info.name}):")
+        print(f"  - col.info.format = {col.info.format}")
+        print(f"  - col.info.name = {col.info.name}")
+        print(f"  - col.info.format in self.formats = {col.info.name in self.formats}")
+        if col.info.name in self.formats:
+            print(f"  - self.formats[{col.info.name}] = {self.formats[col.info.name]}")
+    
+    # Call original method
+    return original_write(self, table)
+
+# Apply monkey patch
+from astropy.io.ascii import html
+original_write = html.HTML.write
+html.HTML.write = debug_write
+
+# generate table
+t = Table([(1.23875234858e-24, 3.2348748432e-15), (2, 4)], names=('a', 'b'))
+tc = t.copy()  # copy table
+
+print("Calling write with formats parameter:")
+with StringIO() as sp:
+    tc.write(sp, format="html", formats={"a": lambda x: f"{x:.2e}"})
+    print("HTML Output:")
+    print(sp.getvalue())
