+#!/usr/bin/env python
+"""
+Comprehensive test for the TimeSeries fix.
+"""
+
+import numpy as np
+from astropy.time import Time
+from astropy.timeseries import TimeSeries
+
+def test_original_issue():
+    """Test the original issue case"""
+    print("=== Testing Original Issue ===")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["time", "flux"]                                   
+    print("Before removing flux column:")
+    print("Columns:", ts.colnames)
+    print("Required columns:", ts._required_columns)
+    
+    try:
+        ts.remove_column("flux")
+        print("ERROR: Should have raised an exception")
+    except ValueError as e:
+        print("Exception raised:")
+        print(f"Error message: {e}")
+        # Check that the error message is now clear
+        assert "missing required columns" in str(e)
+        assert "flux" in str(e)
+        print("✓ Test passed: Clear error message")
+
+def test_no_columns():
+    """Test when no columns are present"""
+    print("\\n=== Testing No Columns ===")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["time", "flux"]
+    
+    # Temporarily disable checks to remove all columns
+    with ts._delay_required_column_checks():
+        ts.remove_column("flux")
+        ts.remove_column("time")
+    
+    # Now try to validate - should get no columns error
+    try:
+        ts._check_required_columns()
+        print("ERROR: Should have raised an exception")
+    except ValueError as e:
+        print("Exception raised:")
+        print(f"Error message: {e}")
+        assert "no columns" in str(e)
+        print("✓ Test passed: No columns error message")
+
+def test_wrong_order():
+    """Test when columns are in wrong order"""
+    print("\\n=== Testing Wrong Order ===")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["flux", "time"]  # Wrong order
+    
+    try:
+        ts._check_required_columns()
+        print("ERROR: Should have raised an exception")
+    except ValueError as e:
+        print("Exception raised:")
+        print(f"Error message: {e}")
+        # This should still show the old behavior for wrong order
+        assert "expected 'flux' as the first column" in str(e)
+        print("✓ Test passed: Wrong order error message")
+
+def test_normal_operation():
+    """Test that normal operations still work"""
+    print("\\n=== Testing Normal Operation ===")
+    time = Time(np.arange(100000, 100003), format='jd')
+    ts = TimeSeries(time=time, data={"flux": [99.9, 99.8, 99.7]})
+    ts._required_columns = ["time", "flux"]
+    
+    # This should work fine
+    print("Before operations:")
+    print("Columns:", ts.colnames)
+    
+    # Add a column
+    ts.add_column([1, 2, 3], name="extra")
+    print("After adding column:")
+    print("Columns:", ts.colnames)
+    
+    # Remove a column that's not required
+    ts.remove_column("extra")
+    print("After removing extra column:")
+    print("Columns:", ts.colnames)
+    
+    # Check that it still validates correctly
+    ts._check_required_columns()
+    print("✓ Test passed: Normal operations work")
+
+if __name__ == "__main__":
+    test_original_issue()
+    test_no_columns()
+    test_wrong_order()
+    test_normal_operation()
+    print("\\n=== All tests completed ===")
