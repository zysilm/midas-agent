+#!/usr/bin/env python
+"""
+Test script to verify the separability_matrix fix for nested CompoundModels
+"""
+from astropy.modeling import models as m
+from astropy.modeling.separable import separability_matrix
+
+def test_original_issue():
+    """Test the exact case from the issue"""
+    print("=== Testing Original Issue ===")
+    
+    # Basic compound model
+    cm = m.Linear1D(10) & m.Linear1D(5)
+    result1 = separability_matrix(cm)
+    print("Basic compound model:")
+    print(result1)
+    print()
+    
+    # Complex compound model
+    result2 = separability_matrix(m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5))
+    print("Complex compound model:")
+    print(result2)
+    print()
+    
+    # Nested compound model (the problematic case)
+    result3 = separability_matrix(m.Pix2Sky_TAN() & cm)
+    print("Nested compound model (should be fixed):")
+    print(result3)
+    print()
+    
+    # Verify the fix: the last 2 rows/columns should be independent (diagonal)
+    expected_last_2_rows_cols = [[True, False], [False, True]]
+    actual_last_2_rows_cols = result3[2:4, 2:4]
+    
+    print("Last 2x2 block of nested model:")
+    print(actual_last_2_rows_cols)
+    print("Expected diagonal pattern:")
+    print(expected_last_2_rows_cols)
+    
+    # Check if they match
+    if (actual_last_2_rows_cols == expected_last_2_rows_cols).all():
+        print("✓ PASS: Last 2x2 block is correctly diagonal")
+        return True
+    else:
+        print("✗ FAIL: Last 2x2 block is not diagonal as expected")
+        return False
+
+def test_additional_cases():
+    """Test additional edge cases"""
+    print("\\n=== Testing Additional Cases ===")
+    
+    # Test with more nesting
+    try:
+        nested1 = (m.Linear1D(1) & m.Linear1D(2)) & m.Linear1D(3)
+        result = separability_matrix(nested1)
+        print("Deeply nested compound model:")
+        print(result)
+        print("✓ PASS: Deep nesting works")
+        return True
+    except Exception as e:
+        print(f"✗ FAIL: Deep nesting failed with error: {e}")
+        return False
+
+def test_backward_compatibility():
+    """Test that existing functionality still works"""
+    print("\\n=== Testing Backward Compatibility ===")
+    
+    # Test simple models
+    try:
+        result = separability_matrix(m.Shift(1) & m.Shift(2))
+        print("Simple shift model:")
+        print(result)
+        print("✓ PASS: Simple models work")
+        return True
+    except Exception as e:
+        print(f"✗ FAIL: Simple models failed with error: {e}")
+        return False
+
+if __name__ == "__main__":
+    success1 = test_original_issue()
+    success2 = test_additional_cases()
+    success3 = test_backward_compatibility()
+    
+    if success1 and success2 and success3:
+        print("\\n🎉 ALL TESTS PASSED!")
+    else:
+        print("\\n❌ SOME TESTS FAILED!")
+        exit(1)
