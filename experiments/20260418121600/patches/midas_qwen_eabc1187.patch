+"""
+Test script to verify the ITRS to Observed transformations.
+"""
+import numpy as np
+from astropy import units as u
+from astropy.coordinates import ITRS, AltAz, HADec, EarthLocation, CIRS
+from astropy.time import Time
+from astropy.coordinates.baseframe import frame_transform_graph
+
+# First, let's see what transformations are registered
+print("=== Checking transformation graph ===")
+print("Looking for ITRS -> AltAz transforms:")
+for t in frame_transform_graph.get_transform(ITRS, AltAz).transforms:
+    print(f"  {t}")
+print("Looking for AltAz -> ITRS transforms:")
+for t in frame_transform_graph.get_transform(AltAz, ITRS).transforms:
+    print(f"  {t}")
+print("Looking for ITRS -> HADec transforms:")
+for t in frame_transform_graph.get_transform(ITRS, HADec).transforms:
+    print(f"  {t}")
+print("Looking for HADec -> ITRS transforms:")
+for t in frame_transform_graph.get_transform(HADec, ITRS).transforms:
+    print(f"  {t}")
+
+# Test case from test_straight_overhead
+t = Time('J2010')
+obj = EarthLocation(-1*u.deg, 52*u.deg, height=10.*u.km)
+home = EarthLocation(-1*u.deg, 52*u.deg, height=0.*u.km)
+
+# Get ITRS position of the object
+itrs_obj = obj.get_itrs(t)
+print(f"\\n=== Test case from test_straight_overhead ===")
+print(f"Object ITRS: {itrs_obj}")
+
+# Transform directly from ITRS to AltAz
+try:
+    altaz = itrs_obj.transform_to(AltAz(obstime=t, location=home))
+    print(f"Direct ITRS->AltAz: alt={altaz.alt}, az={altaz.az}")
+except Exception as e:
+    print(f"Error in direct ITRS->AltAz: {e}")
+
+# Transform via CIRS (current approach)
+cirs_geo = obj.get_itrs(t).transform_to(CIRS(obstime=t))
+obsrepr = home.get_itrs(t).transform_to(CIRS(obstime=t)).cartesian
+cirs_repr = cirs_geo.cartesian - obsrepr
+topocentric_cirs_frame = CIRS(obstime=t, location=home)
+cirs_topo = topocentric_cirs_frame.realize_frame(cirs_repr)
+aa = cirs_topo.transform_to(AltAz(obstime=t, location=home))
+print(f"Via CIRS approach (expected): alt={aa.alt}, az={aa.az}")
+
+# Test round-trip ITRS -> AltAz -> ITRS
+itrs2 = altaz.transform_to(ITRS(obstime=t))
+print(f"Round-trip ITRS: {itrs2}")
+print(f"Original ITRS: {itrs_obj}")
+print(f"Difference: {(itrs_obj.cartesian - itrs2.cartesian).norm()}")
+
+# Test with HADec
+try:
+    hadec = itrs_obj.transform_to(HADec(obstime=t, location=home))
+    print(f"Direct ITRS->HADec: ha={hadec.ha}, dec={hadec.dec}")
+except Exception as e:
+    print(f"Error in direct ITRS->HADec: {e}")
+
+hd = cirs_topo.transform_to(HADec(obstime=t, location=home))
+print(f"Via CIRS approach: ha={hd.ha}, dec={hd.dec}")
