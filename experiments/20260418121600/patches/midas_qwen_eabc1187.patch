+"""
+Comprehensive test script to verify the ITRS to Observed transformations.
+"""
+import numpy as np
+from astropy import units as u
+from astropy.coordinates import ITRS, AltAz, HADec, EarthLocation
+from astropy.time import Time
+from astropy.coordinates.baseframe import frame_transform_graph
+
+print("=== Checking transformation graph ===")
+print("Looking for ITRS -> AltAz transforms:")
+for t in frame_transform_graph.get_transform(ITRS, AltAz).transforms:
+    print(f"  {t}")
+print("Looking for AltAz -> ITRS transforms:")
+for t in frame_transform_graph.get_transform(AltAz, ITRS).transforms:
+    print(f"  {t}")
+print("Looking for ITRS -> HADec transforms:")
+for t in frame_transform_graph.get_transform(ITRS, HADec).transforms:
+    print(f"  {t}")
+print("Looking for HADec -> ITRS transforms:")
+for t in frame_transform_graph.get_transform(HADec, ITRS).transforms:
+    print(f"  {t}")
+
+# Test 1: test_straight_overhead case
+print("\\n=== Test 1: Straight overhead case ===")
+t = Time('J2010')
+obj = EarthLocation(-1*u.deg, 52*u.deg, height=10.*u.km)
+home = EarthLocation(-1*u.deg, 52*u.deg, height=0.*u.km)
+
+itrs_obj = obj.get_itrs(t)
+altaz = itrs_obj.transform_to(AltAz(obstime=t, location=home))
+print(f"ITRS->AltAz: alt={altaz.alt}, az={altaz.az}")
+print(f"Expected alt ~ 90 deg: {np.isclose(altaz.alt.deg, 90, atol=1e-6)}")
+
+hadec = itrs_obj.transform_to(HADec(obstime=t, location=home))
+print(f"ITRS->HADec: ha={hadec.ha}, dec={hadec.dec}")
+print(f"Expected ha ~ 0: {np.isclose(hadec.ha.deg, 0, atol=1e-6)}")
+print(f"Expected dec ~ 52 deg: {np.isclose(hadec.dec.deg, 52, atol=1e-6)}")
+
+# Test 2: Round-trip ITRS -> AltAz -> ITRS
+print("\\n=== Test 2: Round-trip ITRS -> AltAz -> ITRS ===")
+itrs2 = altaz.transform_to(ITRS(obstime=t))
+diff = (itrs_obj.cartesian - itrs2.cartesian).norm()
+print(f"Round-trip difference: {diff}")
+print(f"Expected ~ 0: {diff.to_value(u.m) < 1e-6}")
+
+# Test 3: Round-trip ITRS -> HADec -> ITRS
+print("\\n=== Test 3: Round-trip ITRS -> HADec -> ITRS ===")
+itrs3 = hadec.transform_to(ITRS(obstime=t))
+diff = (itrs_obj.cartesian - itrs3.cartesian).norm()
+print(f"Round-trip difference: {diff}")
+print(f"Expected ~ 0: {diff.to_value(u.m) < 1e-6}")
+
+# Test 4: Round-trip AltAz -> ITRS -> AltAz
+print("\\n=== Test 4: Round-trip AltAz -> ITRS -> AltAz ===")
+altaz2 = itrs2.transform_to(AltAz(obstime=t, location=home))
+diff_alt = (altaz.cartesian - altaz2.cartesian).norm()
+print(f"Round-trip difference: {diff_alt}")
+print(f"Expected ~ 0: {diff_alt.to_value(u.m) < 1e-6}")
+
+# Test 5: Round-trip HADec -> ITRS -> HADec
+print("\\n=== Test 5: Round-trip HADec -> ITRS -> HADec ===")
+hadec2 = itrs3.transform_to(HADec(obstime=t, location=home))
+diff_ha = (hadec.cartesian - hadec2.cartesian).norm()
+print(f"Round-trip difference: {diff_ha}")
+print(f"Expected ~ 0: {diff_ha.to_value(u.m) < 1e-6}")
+
+# Test 6: Different location
+print("\\n=== Test 6: Different location (Greenwich) ===")
+greenwich = EarthLocation(lat=51.4769*u.deg, lon=0.0*u.deg, height=0*u.m)
+itrs_gw = ITRS(x=3980.0*u.km, y=0.0*u.km, z=4966.0*u.km, obstime=t)
+altaz_gw = itrs_gw.transform_to(AltAz(obstime=t, location=greenwich))
+print(f"ITRS->AltAz at Greenwich: alt={altaz_gw.alt}, az={altaz_gw.az}")
+
+# Test 7: With distance
+print("\\n=== Test 7: With distance ===")
+itrs_dist = ITRS(x=4000.0*u.km, y=0.0*u.km, z=5000.0*u.km, obstime=t)
+altaz_dist = itrs_dist.transform_to(AltAz(obstime=t, location=home))
+print(f"ITRS->AltAz with distance: alt={altaz_dist.alt}, az={altaz_dist.az}, distance={altaz_dist.distance}")
+
+# Test 8: Multiple positions
+print("\\n=== Test 8: Multiple positions ===")
+usph = np.linspace(0, 360, 10)*u.deg
+usph2 = np.linspace(-90, 90, 10)*u.deg
+itrs_multi = ITRS(x=np.ones(10)*4000*u.km, y=np.zeros(10)*u.km, z=np.ones(10)*5000*u.km, obstime=t)
+altaz_multi = itrs_multi.transform_to(AltAz(obstime=t, location=home))
+print(f"Multiple positions transformed: {len(altaz_multi)} coordinates")
+
+print("\\n=== All tests completed ===")
