+import numpy as np
+from astropy.modeling import models as m
+from astropy.modeling.separable import _coord_matrix, _cstack, _separable
+
+print("=== Understanding the coordinate matrix construction ===")
+
+# Test simple models
+print("\\n1. Testing simple Linear1D models:")
+linear10 = m.Linear1D(10)
+linear5 = m.Linear1D(5)
+
+print("Linear1D(10) n_inputs:", linear10.n_inputs, "n_outputs:", linear10.n_outputs)
+print("Linear1D(10) separable:", linear10.separable)
+
+# Test what _coord_matrix returns for simple models
+print("\\nCoord matrix for Linear1D(10) as 'left' with noutp=2:")
+try:
+    result = _coord_matrix(linear10, 'left', 2)
+    print(result)
+except Exception as e:
+    print("Error:", e)
+
+print("\\nCoord matrix for Linear1D(10) as 'right' with noutp=2:")
+try:
+    result = _coord_matrix(linear10, 'right', 2)
+    print(result)
+except Exception as e:
+    print("Error:", e)
+
+# Test compound model
+print("\\n2. Testing compound model cm = Linear1D(10) & Linear1D(5):")
+cm = m.Linear1D(10) & m.Linear1D(5)
+print("cm n_inputs:", cm.n_inputs, "n_outputs:", cm.n_outputs)
+print("cm separable:", cm.separable)  # This will fail
+
+print("\\n3. Testing what _separable returns for cm:")
+try:
+    result = _separable(cm)
+    print("cm _separable result:")
+    print(result)
+except Exception as e:
+    print("Error:", e)
+
+print("\\n4. Testing what _coord_matrix returns for cm (this should fail):")
+try:
+    result = _coord_matrix(cm, 'right', 2)
+    print("cm _coord_matrix result:")
+    print(result)
+except Exception as e:
+    print("Error:", e)
+
+print("\\n5. Testing the nested case:")
+nested = m.Pix2Sky_TAN() & cm
+print("nested n_inputs:", nested.n_inputs, "n_outputs:", nested.n_outputs)
+
+print("\\n6. What should happen in _cstack:")
+print("Left model: Pix2Sky_TAN() (noutp=4)")
+print("Right model: cm (noutp=4)")
+
+# Let's manually construct what should happen
+print("\\n7. Manual construction of what _cstack should return:")
+# For Pix2Sky_TAN() as left (non-separable)
+left_coords = np.zeros((4, 2))
+left_coords[:2, :2] = 1  # All 1s for non-separable model
+print("Left coords:")
+print(left_coords)
+
+# For cm as right (should be separable)
+right_coords = np.zeros((4, 2))
+# The cm model has 2 inputs and 2 outputs, and should be separable
+# So the last 2 rows should be identity matrix
+right_coords[2:, :] = np.eye(2)  # Identity matrix for separable model
+print("Right coords (should be identity):")
+print(right_coords)
+
+print("\\n8. What we actually get from _cstack:")
+try:
+    result = _cstack(m.Pix2Sky_TAN(), cm)
+    print(result)
+except Exception as e:
+    print("Error:", e)
+    import traceback
+    traceback.print_exc()
