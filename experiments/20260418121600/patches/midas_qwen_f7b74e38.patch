+import numpy as np
+from astropy.modeling import models as m
+from astropy.modeling.separable import separability_matrix
+
+# Test case 1: Simple compound model
+print("Test case 1: cm = m.Linear1D(10) & m.Linear1D(5)")
+cm = m.Linear1D(10) & m.Linear1D(5)
+result1 = separability_matrix(cm)
+print(result1)
+print("Expected: diagonal matrix [[True, False], [False, True]]")
+
+# Test case 2: More complex compound model
+print("\\nTest case 2: separability_matrix(m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5))")
+result2 = separability_matrix(m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5))
+print(result2)
+print("Expected: [[True, True, False, False], [True, True, False, False], [False, False, True, False], [False, False, False, True]]")
+
+# Test case 3: Nested compound model (the problematic case)
+print("\\nTest case 3: separability_matrix(m.Pix2Sky_TAN() & cm)")
+result3 = separability_matrix(m.Pix2Sky_TAN() & cm)
+print(result3)
+print("Expected: same as test case 2, but got a different pattern")
+
+# Let's also check what the model structure looks like
+print("\\nModel structure analysis:")
+nested_model = m.Pix2Sky_TAN() & cm
+print(f"m.Pix2Sky_TAN() & cm has n_inputs = {nested_model.n_inputs}")
+print(f"m.Pix2Sky_TAN() & cm has n_outputs = {nested_model.n_outputs}")
+print(f"m.Pix2Sky_TAN() has n_inputs = {m.Pix2Sky_TAN().n_inputs}")
+print(f"m.Pix2Sky_TAN() has n_outputs = {m.Pix2Sky_TAN().n_outputs}")
+print(f"cm has n_inputs = {cm.n_inputs}")
+print(f"cm has n_outputs = {cm.n_outputs}")
+
+# Let's also check the individual components
+print("\\nIndividual component separability:")
+print(f"m.Pix2Sky_TAN().separable = {m.Pix2Sky_TAN().separable}")
+print(f"m.Linear1D(10).separable = {m.Linear1D(10).separable}")
+print(f"m.Linear1D(5).separable = {m.Linear1D(5).separable}")
+
+# Let's try to flatten the nested model and compare
+print("\\nFlattened model comparison:")
+flattened = m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)
+print(f"Flattened model separability matrix:")
+print(separability_matrix(flattened))
+print(f"Nested model separability matrix:")
+print(result3)
+
+# Check if they're the same
+print(f"\\nAre the matrices equal? {np.array_equal(result3, separability_matrix(flattened))}")
+
+# Let's see the structure of the nested model
+print("\\nNested model structure:")
+print(f"m.Pix2Sky_TAN() & cm.__class__ = {type(nested_model)}")
+print(f"m.Pix2Sky_TAN() & cm.left.__class__ = {type(nested_model.left)}")
+print(f"m.Pix2Sky_TAN() & cm.right.__class__ = {type(nested_model.right)}")
+print(f"m.Pix2Sky_TAN() & cm.right.left.__class__ = {type(nested_model.right.left)}")
+print(f"m.Pix2Sky_TAN() & cm.right.right.__class__ = {type(nested_model.right.right)}")
+
+# Let's try to understand the problem by examining the _cstack function and how it handles nested models
+print("\\nDebugging _cstack behavior:")
+
+# Create a simple test case to understand the issue
+print("\\nSimple test case for debugging:")
+left_model = m.Pix2Sky_TAN()
+right_model = cm
+noutp = left_model.n_outputs + right_model.n_outputs
+
+print(f"left_model.n_outputs = {left_model.n_outputs}")
+print(f"right_model.n_outputs = {right_model.n_outputs}")
+print(f"noutp = {noutp}")
+
+# This is what happens in _cstack function
+left_coords = np.zeros((noutp, left_model.n_inputs))
+left_coords[:left_model.n_outputs, :left_model.n_inputs] = 1
+
+right_coords = np.zeros((noutp, right_model.n_inputs))
+right_coords[-right_model.n_outputs:, -right_model.n_inputs:] = 1
+
+print(f"left_coords shape: {left_coords.shape}")
+print(f"right_coords shape: {right_coords.shape}")
+print(f"left_coords:\\n{left_coords}")
+print(f"right_coords:\\n{right_coords}")
+
+final_matrix = np.hstack([left_coords, right_coords])
+print(f"final_matrix:\\n{final_matrix}")
+
+# Now let's see what the actual _cstack function returns
+print("\\nActual _cstack result:")
+from astropy.modeling.separable import _cstack
+actual_result = _cstack(left_model, right_model)
+print(f"actual_result:\\n{actual_result}")
+
+# Compare with what we expect
+expected_result = np.array([[ True,  True, False, False],
+                            [ True,  True, False, False],
+                            [False, False,  True, False],
+                            [False, False, False,  True]])
+print(f"Expected result:\\n{expected_result}")
+print(f"Are they equal? {np.array_equal(actual_result, expected_result)}")
+
+# Let's also check the _separable function behavior
+print("\\nDebugging _separable function:")
+from astropy.modeling.separable import _separable
+
+print("Testing _separable on nested model:")
+nested_separable = _separable(nested_model)
+print(f"_separable result for nested model:\\n{nested_separable}")
+
+print("Testing _separable on flattened model:")
+flattened_separable = _separable(flattened)
+print(f"_separable result for flattened model:\\n{flattened_separable}")
+
+print(f"Are _separable results equal? {np.array_equal(nested_separable, flattened_separable)}")
