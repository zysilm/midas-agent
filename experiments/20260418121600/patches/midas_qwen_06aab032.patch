+# The correct approach would be to make sure we're passing the right types
+# Let's see what the correct separability matrix should be
+print("Expected result for pix2sky & cm:")
+print("pix2sky has 2 outputs, cm has 2 outputs")
+print("So result should be 4x2 matrix")
+print("First 2 rows should be like pix2sky's separability")
+print("Last 2 rows should be like cm's separability")
+expected = np.array([
+    [True, True],   # pix2sky output 1
+    [True, True],   # pix2sky output 2
+    [True, False],  # cm output 1 (linear1)
+    [False, True]   # cm output 2 (linear2)
+])
+print(expected)
