+import numpy as np
+from astropy.modeling import models as m
+from astropy.modeling.separable import separability_matrix
+
+# Test case 1: Simple compound model
+print("Test case 1: Simple compound model")
+cm = m.Linear1D(10) & m.Linear1D(5)
+print("Model structure: Linear1D(10) & Linear1D(5)")
+print("Separability matrix:")
+print(separability_matrix(cm))
+print()
+
+# Test case 2: More complex model
+print("Test case 2: More complex model")
+cm2 = m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)
+print("Model structure: Pix2Sky_TAN() & Linear1D(10) & Linear1D(5)")
+print("Separability matrix:")
+print(separability_matrix(cm2))
+print()
+
+# Test case 3: Nested compound model (the problematic case)
+print("Test case 3: Nested compound model")
+cm3 = m.Pix2Sky_TAN() & cm  # cm is the compound model from test case 1
+print("Model structure: Pix2Sky_TAN() & (Linear1D(10) & Linear1D(5))")
+print("Separability matrix:")
+print(separability_matrix(cm3))
+print()
+
+# Let's also check the structure of the compound models
+cm3_left = cm3.left
+print(f"Left model of cm3: {type(cm3_left).__name__}")
+print(f"Left model n_inputs: {cm3_left.n_inputs}, n_outputs: {cm3_left.n_outputs}")
+print(f"Right model of cm3: {type(cm3.right).__name__}")
+print(f"Right model n_inputs: {cm3.right.n_inputs}, n_outputs: {cm3.right.n_outputs}")
+
+# Check the separability matrix of the nested compound model directly
+print("\\nSeparability matrix of nested compound model (cm):")
+print(separability_matrix(cm))
