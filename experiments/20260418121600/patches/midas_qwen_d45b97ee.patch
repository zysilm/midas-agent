+import numpy as np
+import astropy.wcs
+from astropy.coordinates import SkyCoord
+import astropy.units as u
+
+# Test a simpler case to understand the problem
+nx = 100
+ny = 25
+nz = 2
+wcs_header = {
+    'WCSAXES': 3,
+    'CRPIX1': (nx + 1)/2,
+    'CRPIX2': (ny + 1)/2,
+    'CRPIX3': 1.0,
+    'PC1_1': 0.0,
+    'PC1_2': -1.0,
+    'PC1_3': 0.0,
+    'PC2_1': 1.0,
+    'PC2_2': 0.0,
+    'PC2_3': -1.0,
+    'CDELT1': 5,
+    'CDELT2': 5,
+    'CDELT3': 0.055,
+    'CUNIT1': 'arcsec',
+    'CUNIT2': 'arcsec',
+    'CUNIT3': 'Angstrom',
+    'CTYPE1': 'HPLN-TAN',
+    'CTYPE2': 'HPLT-TAN',
+    'CTYPE3': 'WAVE',
+    'CRVAL1': 0.0,
+    'CRVAL2': 0.0,
+    'CRVAL3': 1.05,
+}
+
+fits_wcs = astropy.wcs.WCS(header=wcs_header)
+
+print("=== Understanding the problem ===")
+print("Original WCS:")
+print("  pixel_n_dim:", fits_wcs.pixel_n_dim)
+print("  world_n_dim:", fits_wcs.world_n_dim)
+print("  CRVAL3:", fits_wcs.wcs.crval[2])
+
+# Test what happens with the full WCS
+print("\\nFull WCS world_to_pixel with 3D coordinates:")
+px_full, py_full, pz_full = fits_wcs.world_to_pixel(0*u.arcsec, 0*u.arcsec, 1.05*u.angstrom)
+print(f"  Result: ({px_full}, {py_full}, {pz_full})")
+
+# Test what happens with slicing
+print("\\nSlicing with integer 0 (first dimension):")
+ll_sliced_wcs = astropy.wcs.wcsapi.SlicedLowLevelWCS(fits_wcs, 0)
+print("  _slices_array:", ll_sliced_wcs._slices_array)
+print("  _slices_pixel:", ll_sliced_wcs._slices_pixel)
+print("  _world_keep:", ll_sliced_wcs._world_keep)
+print("  _pixel_keep:", ll_sliced_wcs._pixel_keep)
+
+# What should happen when we call world_to_pixel on the sliced WCS?
+# The sliced WCS has 2 world dimensions (indices 1,2) and 2 pixel dimensions (indices 0,1)
+# So we should be able to call world_to_pixel with 2 arguments
+
+print("\\nWhat should happen:")
+print("  Sliced WCS has 2 world dimensions (spatial x, spatial y)")
+print("  Sliced WCS has 2 pixel dimensions (pixel x, pixel y)")
+print("  So we should call world_to_pixel with 2 arguments (spatial x, spatial y)")
+print("  But the underlying implementation is trying to handle 3D world coordinates")
+
+# Let's see what happens if we manually call the world_to_pixel_values method
+print("\\nTesting world_to_pixel_values directly:")
+try:
+    result = ll_sliced_wcs.world_to_pixel_values(0*u.arcsec, 0*u.arcsec)
+    print(f"  Direct call result: {result}")
+except Exception as e:
+    print(f"  Direct call error: {e}")
