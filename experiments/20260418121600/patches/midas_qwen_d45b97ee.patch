+hl_sliced_wcs = astropy.wcs.wcsapi.HighLevelWCSWrapper(ll_sliced_wcs)
+
+print("\\nSliced WCS world_to_pixel:")
+px_sliced, py_sliced = hl_sliced_wcs.world_to_pixel(0*u.arcsec, 0*u.arcsec)
+print(f"Result: ({px_sliced}, {py_sliced})")
+
+# Verify that pixel_to_world works correctly
+print("\\nVerifying pixel_to_world (should work correctly):")
+px, py, pz = fits_wcs.world_to_pixel(0*u.arcsec, 0*u.arcsec, 1.05*u.angstrom)
+print("Full WCS pixel_to_world:")
