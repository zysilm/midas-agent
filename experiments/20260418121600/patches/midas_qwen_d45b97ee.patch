+px_bad, py_bad, pz_bad = fits_wcs.world_to_pixel(0*u.arcsec, 0*u.arcsec, 1.0*u.angstrom)
+print(f"Result with 1.0: ({px_bad}, {py_bad}, {pz_bad})")
