+#!/usr/bin/env python
+"""Test edge cases for the is_fits fix"""
+
+from astropy.io.registry import identify_format
+from astropy.table import Table
+import tempfile
+import os
+
+print("Testing edge cases...")
+
+# Test 1: Empty string filepath
+print("Test 1: Empty string filepath")
+try:
+    result = identify_format("write", Table, "", None, [], {})
+    print(f"  Result: {result}")
+    print("  ✓ PASS")
+except Exception as e:
+    print(f"  ✗ FAIL: {type(e).__name__}: {e}")
+
+# Test 2: None filepath
+print("Test 2: None filepath")
+try:
+    result = identify_format("write", Table, None, None, [], {})
+    print(f"  Result: {result}")
+    print("  ✓ PASS")
+except Exception as e:
+    print(f"  ✗ FAIL: {type(e).__name__}: {e}")
+
+# Test 3: Various non-FITS extensions
+print("Test 3: Various non-FITS extensions")
+extensions = [".txt", ".csv", ".json", ".dat", ".xml", ".html", ".pdf"]
+for ext in extensions:
+    try:
+        result = identify_format("write", Table, f"test{ext}", None, [], {})
+        print(f"  {ext}: {result}")
+    except Exception as e:
+        print(f"  {ext}: ✗ FAIL: {type(e).__name__}: {e}")
+
+# Test 4: Various FITS extensions
+print("Test 4: Various FITS extensions")
+fits_extensions = [".fits", ".fits.gz", ".fit", ".fit.gz", ".fts", ".fts.gz"]
+for ext in fits_extensions:
+    try:
+        result = identify_format("write", Table, f"test{ext}", None, [], {})
+        print(f"  {ext}: {result}")
+    except Exception as e:
+        print(f"  {ext}: ✗ FAIL: {type(e).__name__}: {e}")
+
+print("Edge case testing completed!")
