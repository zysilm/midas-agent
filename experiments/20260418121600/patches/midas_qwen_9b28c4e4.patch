+#!/usr/bin/env python
+"""Comprehensive test for the is_fits fix"""
+
+from astropy.io.registry import identify_format
+from astropy.table import Table
+import tempfile
+import os
+
+print("Testing comprehensive cases...")
+
+# Test case 1: Original failing case
+print("Test 1: Non-FITS extension file")
+try:
+    result = identify_format("write", Table, "bububu.ecsv", None, [], {})
+    print(f"  Result: {result}")
+    print("  ✓ PASS")
+except Exception as e:
+    print(f"  ✗ FAIL: {type(e).__name__}: {e}")
+
+# Test case 2: FITS extension file
+print("Test 2: FITS extension file")
+try:
+    result = identify_format("write", Table, "test.fits", None, [], {})
+    print(f"  Result: {result}")
+    print("  ✓ PASS")
+except Exception as e:
+    print(f"  ✗ FAIL: {type(e).__name__}: {e}")
+
+# Test case 3: File with no extension
+print("Test 3: File with no extension")
+try:
+    result = identify_format("write", Table, "testfile", None, [], {})
+    print(f"  Result: {result}")
+    print("  ✓ PASS")
+except Exception as e:
+    print(f"  ✗ FAIL: {type(e).__name__}: {e}")
+
+# Test case 4: Empty args but with fileobj
+print("Test 4: With fileobj")
+try:
+    # Create a temporary file
+    with tempfile.NamedTemporaryFile(suffix='.fits', delete=False) as tmp:
+        tmp_path = tmp.name
+    result = identify_format("write", Table, None, tmp_path, [], {})
+    print(f"  Result: {result}")
+    print("  ✓ PASS")
+    # Clean up
+    os.unlink(tmp_path)
+except Exception as e:
+    print(f"  ✗ FAIL: {type(e).__name__}: {e}")
+
+# Test case 5: Empty args and fileobj
+print("Test 5: With fileobj but no extension")
+try:
+    # Create a temporary file with no extension
+    with tempfile.NamedTemporaryFile(delete=False) as tmp:
+        tmp_path = tmp.name
+    result = identify_format("write", Table, None, tmp_path, [], {})
+    print(f"  Result: {result}")
+    print("  ✓ PASS")
+    # Clean up
+    os.unlink(tmp_path)
+except Exception as e:
+    print(f"  ✗ FAIL: {type(e).__name__}: {e}")
+
+print("All tests completed!")
